      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&family=DM+Sans:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap');\n    @import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css');\n\n    :root {\n        --gold: #E8A020;\n        --gold-deep: #C47810;\n        --dark: #080808;\n        --charcoal: #111111;\n        --light: #FBFCFD;\n    }\n\n    .font-display { font-family: 'Cormorant Garamond', serif; }\n    .font-body { font-family: 'DM Sans', sans-serif; }\n    .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n    .gold-gradient-text {\n        background: linear-gradient(135deg, #E8A020 0%, #C47810 100%);\n        -webkit-background-clip: text;\n        -webkit-text-fill-color: transparent;\n    }\n\n    .glass-card {\n        background: rgba(255, 255, 255, 0.03);\n        backdrop-filter: blur(20px);\n        border: 1px solid rgba(255, 255, 255, 0.08);\n    }\n\n    .portfolio-grid {\n        display: grid;\n        grid-template-columns: repeat(12, 1fr);\n        gap: 1.5rem;\n    }\n\n    /* Asymmetric logic */\n    .portfolio-item-large { grid-column: span 7; }\n    .portfolio-item-medium { grid-column: span 5; }\n    \n    @media (max-width: 768px) {\n        .portfolio-item-large, .portfolio-item-medium { grid-column: span 12; }\n    }\n\n    .reveal-text {\n        animation: reveal 1.2s cubic-bezier(0.77, 0, 0.175, 1) forwards;\n    }\n\n    @keyframes reveal {\n        0% { transform: translateY(100%); opacity: 0; }\n        100% { transform: translateY(0); opacity: 1; }\n    }\n</style>\n\n<div class=\"font-body text-[#F5F5F5] bg-[var(--dark)] selection:bg-[var(--gold)]/30\" data-kid=\"1\">\n    \n    \n    <nav class=\"absolute top-0 left-0 right-0 z-50 flex items-center justify-between px-8 md:px-16 py-10\" data-kid=\"2\">\n        <div class=\"flex items-center gap-2\" data-kid=\"3\">\n            <span class=\"font-display text-2xl tracking-[0.25em] font-light text-white uppercase\" data-kid=\"4\">\n                <span class=\"text-[var(--gold)]\" data-kid=\"5\">V</span>eltora\n            </span>\n        </div>\n        <div class=\"hidden lg:flex items-center gap-12 font-mono text-[10px] uppercase tracking-[0.3em] text-white/60\" data-kid=\"6\">\n            <a href=\"javascript:void(0)\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"7\">Portfolio</a>\n            <a href=\"javascript:void(0)\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"8\">Services</a>\n            <a href=\"javascript:void(0)\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"9\">Process</a>\n            <a href=\"javascript:void(0)\" class=\"px-6 py-2 border border-[var(--gold)]/30 rounded-full hover:bg-[var(--gold)] hover:text-[var(--dark)] transition-all text-white\" data-kid=\"10\">Start Project</a>\n        </div>\n    </nav>\n\n    \n    <section class=\"relative h-[900px] w-full overflow-hidden flex items-center justify-center\" data-kid=\"11\">\n        \n        <img src=\"https://images.unsplash.com/photo-1772147062749-06375bf17bae?auto=format&w=1920&q=85&fit=crop\" alt=\"Cinematic Landscape\" class=\"absolute inset-0 w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"12\">\n        \n        <div class=\"absolute inset-0 bg-gradient-to-b from-[var(--dark)]/40 via-transparent to-[var(--dark)]\" data-kid=\"13\"></div>\n        <div class=\"absolute inset-0 bg-[var(--dark)]/20\" data-kid=\"14\"></div>\n\n        <div class=\"relative z-10 text-center max-w-5xl px-6\" data-kid=\"15\">\n            <p class=\"font-mono text-[var(--gold)] uppercase tracking-[0.5em] text-[10px] mb-8 animate-pulse\" data-kid=\"16\">\n                Creative Engineering Studio\n            </p>\n            <h1 class=\"font-display text-6xl md:text-9xl font-light leading-[1.05] tracking-tight mb-8 [text-shadow:0_10px_30px_rgba(0,0,0,0.5)]\" data-kid=\"17\">\n                Precision-built <br data-kid=\"18\">\n                <span class=\"italic gold-gradient-text\" data-kid=\"19\">digital experiences.</span>\n            </h1>\n            <p class=\"text-lg md:text-xl text-white/60 max-w-2xl mx-auto mb-14 font-light leading-relaxed\" data-kid=\"20\">\n                We craft high-fidelity digital products for brands that demand cinematic quality and technical supremacy.\n            </p>\n            <div class=\"flex justify-center\" data-kid=\"21\">\n                <a href=\"#contact\" class=\"px-12 py-5 bg-[var(--gold)] text-[var(--dark)] rounded-full font-bold text-sm uppercase tracking-widest hover:scale-105 hover:bg-[var(--gold-deep)] transition-all shadow-xl shadow-[var(--gold)]/10\" data-kid=\"22\">\n                    Start a project\n                </a>\n            </div>\n        </div>\n\n        \n        <div class=\"absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4\" data-kid=\"23\">\n            <span class=\"font-mono text-[9px] uppercase tracking-[0.4em] text-white/30\" data-kid=\"24\">Explore</span>\n            <div class=\"w-[1px] h-20 bg-gradient-to-b from-[var(--gold)] to-transparent\" data-kid=\"25\"></div>\n        </div>\n    </section>\n\n    \n    <section id=\"services\" class=\"bg-[var(--light)] py-32 md:py-48 px-8 md:px-24\" data-kid=\"26\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"27\">\n            \n            <div class=\"mb-40 grid grid-cols-1 lg:grid-cols-12 gap-16 items-start\" data-kid=\"28\">\n                <div class=\"lg:col-span-4\" data-kid=\"29\">\n                    <p class=\"font-mono text-[var(--gold)] uppercase tracking-[0.4em] text-[10px] mb-6\" data-kid=\"30\">Our Manifesto</p>\n                    <h2 class=\"font-display text-4xl text-[var(--dark)] leading-tight italic\" data-kid=\"31\">\n                        \"One person. <br data-kid=\"32\">Full studio output.\"\n                    </h2>\n                </div>\n                <div class=\"lg:col-span-8\" data-kid=\"33\">\n                    <p class=\"text-[var(--dark)]/70 text-xl font-light leading-relaxed mb-8\" data-kid=\"34\">\n                        I built Veltora because I saw too many brands with great ideas but weak digital presence. I do both sides: write every line of code and design every pixel. No miscommunication. No middleman. Just precision.\n                    </p>\n                    <div class=\"flex gap-12 border-t border-black/5 pt-8\" data-kid=\"35\">\n                        <div data-kid=\"36\">\n                            <span class=\"block font-display text-2xl text-[var(--dark)]\" data-kid=\"37\">ALX</span>\n                            <span class=\"text-[9px] font-mono uppercase tracking-widest text-gray-400\" data-kid=\"38\">Certified Engineer</span>\n                        </div>\n                        <div data-kid=\"39\">\n                            <span class=\"block font-display text-2xl text-[var(--dark)]\" data-kid=\"40\">Pretoria</span>\n                            <span class=\"text-[9px] font-mono uppercase tracking-widest text-gray-400\" data-kid=\"41\">Base of Operations</span>\n                        </div>\n                        <div data-kid=\"42\">\n                            <span class=\"block font-display text-2xl text-[var(--dark)]\" data-kid=\"43\">Kenyan</span>\n                            <span class=\"text-[9px] font-mono uppercase tracking-widest text-gray-400\" data-kid=\"44\">Design Heritage</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"flex flex-col md:flex-row md:items-end justify-between mb-24 gap-8\" data-kid=\"45\">\n                <div class=\"max-w-2xl\" data-kid=\"46\">\n                    <p class=\"font-mono text-[var(--gold)] uppercase tracking-[0.4em] text-[10px] mb-6\" data-kid=\"47\">Core Architectures</p>\n                    <h2 class=\"font-display text-5xl md:text-7xl text-[var(--dark)] font-light leading-tight\" data-kid=\"48\">\n                        Scalable Digital <br data-kid=\"49\">\n                        <span class=\"italic text-gray-300\" data-kid=\"50\">Foundations.</span>\n                    </h2>\n                </div>\n                <div class=\"md:max-w-xs\" data-kid=\"51\">\n                    <p class=\"text-[var(--dark)]/50 text-sm leading-relaxed\" data-kid=\"52\">\n                        Every project is built with proprietary performance standards and conversion-led design principles.\n                    </p>\n                </div>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-10\" data-kid=\"53\">\n                \n                <div class=\"p-12 bg-white rounded-[12px] border border-gray-100 flex flex-col justify-between hover:shadow-2xl hover:shadow-gray-200/50 transition-all group\" data-kid=\"54\">\n                    <div data-kid=\"55\">\n                        <span class=\"font-mono text-[9px] uppercase tracking-widest text-gray-400 mb-8 block\" data-kid=\"56\">01 / Foundation</span>\n                        <h3 class=\"font-display text-4xl text-[var(--dark)] mb-6\" data-kid=\"57\">Forge</h3>\n                        <p class=\"text-gray-500 text-sm mb-10 leading-relaxed font-light\" data-kid=\"58\">Rapid deployment architecture for emerging brands requiring immediate prestige and stability.</p>\n                        <ul class=\"space-y-4 mb-12\" data-kid=\"59\">\n                            <li class=\"flex items-center gap-3 text-xs text-[var(--dark)] font-medium\" data-kid=\"60\">\n                                <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--gold)]\" data-kid=\"61\"></span> 4-Page Architecture\n                            </li>\n                            <li class=\"flex items-center gap-3 text-xs text-[var(--dark)] font-medium\" data-kid=\"62\">\n                                <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--gold)]\" data-kid=\"63\"></span> Mobile Responsive\n                            </li>\n                            <li class=\"flex items-center gap-3 text-xs text-[var(--dark)] font-medium\" data-kid=\"64\">\n                                <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--gold)]\" data-kid=\"65\"></span> Standard SEO\n                            </li>\n                        </ul>\n                    </div>\n                    <button class=\"w-full py-4 rounded-full border border-gray-200 text-[10px] font-bold uppercase tracking-widest text-[var(--dark)] hover:bg-[var(--dark)] hover:text-white transition-all\" data-kid=\"66\">Configure Forge</button>\n                </div>\n\n                \n                <div class=\"p-12 bg-white rounded-[12px] border border-[var(--gold)]/20 relative shadow-[0_40px_100px_rgba(232,160,32,0.1)] flex flex-col justify-between transform md:-translate-y-8 z-10 overflow-hidden\" data-kid=\"67\">\n                    <div class=\"absolute top-0 right-0 p-6 opacity-5 pointer-events-none\" data-kid=\"68\">\n                        <span class=\"font-display text-9xl leading-none italic font-bold\" data-kid=\"69\">V</span>\n                    </div>\n                    <div class=\"absolute top-0 left-0 w-full h-1 bg-[var(--gold)]\" data-kid=\"70\"></div>\n                    \n                    <div data-kid=\"71\">\n                        <div class=\"flex justify-between items-center mb-8\" data-kid=\"72\">\n                            <span class=\"font-mono text-[9px] uppercase tracking-widest text-[var(--gold)] font-bold\" data-kid=\"73\">02 / Momentum</span>\n                            <span class=\"px-3 py-1 bg-[var(--gold)]/10 text-[var(--gold)] text-[8px] font-bold uppercase tracking-widest rounded-full\" data-kid=\"74\">Most Popular</span>\n                        </div>\n                        <h3 class=\"font-display text-4xl text-[var(--dark)] mb-6\" data-kid=\"75\">Velocity</h3>\n                        <p class=\"text-gray-500 text-sm mb-10 leading-relaxed font-light\" data-kid=\"76\">High-velocity infrastructure designed for rapid scaling and complex conversion funnels.</p>\n                        <ul class=\"space-y-4 mb-12\" data-kid=\"77\">\n                            <li class=\"flex items-center gap-3 text-xs text-[var(--dark)] font-bold\" data-kid=\"78\">\n                                <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--gold)] shadow-[0_0_8px_var(--gold)]\" data-kid=\"79\"></span> Custom Design System\n                            </li>\n                            <li class=\"flex items-center gap-3 text-xs text-[var(--dark)] font-bold\" data-kid=\"80\">\n                                <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--gold)] shadow-[0_0_8px_var(--gold)]\" data-kid=\"81\"></span> CMS Infrastructure\n                            </li>\n                            <li class=\"flex items-center gap-3 text-xs text-[var(--dark)] font-bold\" data-kid=\"82\">\n                                <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--gold)] shadow-[0_0_8px_var(--gold)]\" data-kid=\"83\"></span> Advanced SEO Strategy\n                            </li>\n                            <li class=\"flex items-center gap-3 text-xs text-[var(--dark)] font-bold\" data-kid=\"84\">\n                                <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--gold)] shadow-[0_0_8px_var(--gold)]\" data-kid=\"85\"></span> Priority Delivery\n                            </li>\n                        </ul>\n                    </div>\n                    <button class=\"w-full py-4 rounded-full bg-[var(--gold)] text-[var(--dark)] text-[10px] font-bold uppercase tracking-widest hover:bg-[var(--gold-deep)] transition-all shadow-lg shadow-[var(--gold)]/20\" data-kid=\"86\">Forge Velocity</button>\n                </div>\n\n                \n                <div class=\"p-12 bg-white rounded-[12px] border border-gray-100 flex flex-col justify-between hover:shadow-2xl hover:shadow-gray-200/50 transition-all\" data-kid=\"87\">\n                    <div data-kid=\"88\">\n                        <span class=\"font-mono text-[9px] uppercase tracking-widest text-gray-400 mb-8 block\" data-kid=\"89\">03 / Supremacy</span>\n                        <h3 class=\"font-display text-4xl text-[var(--dark)] mb-6\" data-kid=\"90\">Apex</h3>\n                        <p class=\"text-gray-500 text-sm mb-10 leading-relaxed font-light\" data-kid=\"91\">The pinnacle of digital craftsmanship. Bespoke ecosystems with deep logic integrations.</p>\n                        <ul class=\"space-y-4 mb-12\" data-kid=\"92\">\n                            <li class=\"flex items-center gap-3 text-xs text-[var(--dark)] font-medium\" data-kid=\"93\">\n                                <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--gold)]\" data-kid=\"94\"></span> Bespoke Web Apps\n                            </li>\n                            <li class=\"flex items-center gap-3 text-xs text-[var(--dark)] font-medium\" data-kid=\"95\">\n                                <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--gold)]\" data-kid=\"96\"></span> Database Logic\n                            </li>\n                            <li class=\"flex items-center gap-3 text-xs text-[var(--dark)] font-medium\" data-kid=\"97\">\n                                <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--gold)]\" data-kid=\"98\"></span> Dedicated Support\n                            </li>\n                        </ul>\n                    </div>\n                    <button class=\"w-full py-4 rounded-full border border-gray-200 text-[10px] font-bold uppercase tracking-widest text-[var(--dark)] hover:bg-[var(--dark)] hover:text-white transition-all\" data-kid=\"99\">Request Apex</button>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"bg-[var(--light)] pb-48 px-8 md:px-24\" data-kid=\"100\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"101\">\n            <div class=\"grid grid-cols-1 md:grid-cols-4 gap-12\" data-kid=\"102\">\n                <div class=\"p-10 border-l border-black/5 hover:border-[var(--gold)] transition-all group bg-white/40 backdrop-blur-sm rounded-r-lg\" data-kid=\"103\">\n                    <span class=\"font-mono text-[10px] text-[var(--gold)] block mb-4\" data-kid=\"104\">Phase 01</span>\n                    <h4 class=\"font-display text-2xl text-[var(--dark)] mb-4\" data-kid=\"105\">Discovery</h4>\n                    <p class=\"text-xs text-gray-500 font-light leading-relaxed\" data-kid=\"106\">Deep analysis of brand goals, user psychographics, and technical constraints.</p>\n                </div>\n                <div class=\"p-10 border-l border-black/5 hover:border-[var(--gold)] transition-all group bg-white/40 backdrop-blur-sm rounded-r-lg\" data-kid=\"107\">\n                    <span class=\"font-mono text-[10px] text-[var(--gold)] block mb-4\" data-kid=\"108\">Phase 02</span>\n                    <h4 class=\"font-display text-2xl text-[var(--dark)] mb-4\" data-kid=\"109\">Design</h4>\n                    <p class=\"text-xs text-gray-500 font-light leading-relaxed\" data-kid=\"110\">Crafting the cinematic visual language and interface logic in high-fidelity.</p>\n                </div>\n                <div class=\"p-10 border-l border-black/5 hover:border-[var(--gold)] transition-all group bg-white/40 backdrop-blur-sm rounded-r-lg\" data-kid=\"111\">\n                    <span class=\"font-mono text-[10px] text-[var(--gold)] block mb-4\" data-kid=\"112\">Phase 03</span>\n                    <h4 class=\"font-display text-2xl text-[var(--dark)] mb-4\" data-kid=\"113\">Build</h4>\n                    <p class=\"text-xs text-gray-500 font-light leading-relaxed\" data-kid=\"114\">Performance-first engineering using Next.js, Tailwind, and Supabase.</p>\n                </div>\n                <div class=\"p-10 border-l border-black/5 hover:border-[var(--gold)] transition-all group bg-white/40 backdrop-blur-sm rounded-r-lg\" data-kid=\"115\">\n                    <span class=\"font-mono text-[10px] text-[var(--gold)] block mb-4\" data-kid=\"116\">Phase 04</span>\n                    <h4 class=\"font-display text-2xl text-[var(--dark)] mb-4\" data-kid=\"117\">Launch</h4>\n                    <p class=\"text-xs text-gray-500 font-light leading-relaxed\" data-kid=\"118\">Global deployment with ongoing optimization and technical supremacy.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n                    <div data-kid=\"119\">\n                        <span class=\"font-mono text-[9px] uppercase tracking-widest text-gray-400 mb-8 block\" data-kid=\"120\">03 / Supremacy</span>\n                        <h3 class=\"font-display text-4xl text-[var(--dark)] mb-6\" data-kid=\"121\">Apex</h3>\n                        <p class=\"text-gray-500 text-sm mb-10 leading-relaxed font-light\" data-kid=\"122\">The pinnacle of digital craftsmanship. Bespoke ecosystems with deep logic integrations.</p>\n                        <ul class=\"space-y-4 mb-12\" data-kid=\"123\">\n                            <li class=\"flex items-center gap-3 text-xs text-[var(--dark)] font-medium\" data-kid=\"124\">\n                                <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--gold)]\" data-kid=\"125\"></span> Bespoke Web Apps\n                            </li>\n                            <li class=\"flex items-center gap-3 text-xs text-[var(--dark)] font-medium\" data-kid=\"126\">\n                                <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--gold)]\" data-kid=\"127\"></span> Database Logic\n                            </li>\n                            <li class=\"flex items-center gap-3 text-xs text-[var(--dark)] font-medium\" data-kid=\"128\">\n                                <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--gold)]\" data-kid=\"129\"></span> Dedicated Support\n                            </li>\n                        </ul>\n                    </div>\n                    <button class=\"w-full py-4 rounded-full border border-gray-200 text-[10px] font-bold uppercase tracking-widest text-[var(--dark)] hover:bg-[var(--dark)] hover:text-white transition-all\" data-kid=\"130\">Request Apex</button>\n                </div>\n            \n        \n    \n\n    \n    <section class=\"bg-[var(--charcoal)] py-40 px-8 md:px-24 relative overflow-hidden\" data-kid=\"131\">\n        \n        <div class=\"absolute top-1/2 left-0 w-[500px] h-[500px] bg-[var(--gold)]/5 rounded-full blur-[120px] -translate-x-1/2 -translate-y-1/2\" data-kid=\"132\"></div>\n        \n        <div class=\"max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-24 relative z-10\" data-kid=\"133\">\n            <div class=\"lg:w-1/2\" data-kid=\"134\">\n                <p class=\"font-mono text-[var(--gold)] uppercase tracking-[0.4em] text-[10px] mb-8\" data-kid=\"135\">Proprietary Performance</p>\n                <h2 class=\"font-display text-5xl md:text-7xl font-light leading-tight mb-10\" data-kid=\"136\">\n                    Veltora <span class=\"italic gold-gradient-text\" data-kid=\"137\">Engine.</span>\n                </h2>\n                <p class=\"text-white/50 text-lg font-light leading-relaxed mb-12 max-w-xl\" data-kid=\"138\">\n                    Our performance dashboard integrates directly with your core web vitals, providing a cinematic view of your digital health. We don't just optimize; we dominate.\n                </p>\n                \n                <div class=\"grid grid-cols-2 gap-10\" data-kid=\"139\">\n                    <div class=\"space-y-4\" data-kid=\"140\">\n                        <div class=\"flex justify-between items-end\" data-kid=\"141\">\n                            <span class=\"font-mono text-[10px] uppercase tracking-widest text-white/40\" data-kid=\"142\">LCP Metrics</span>\n                            <span class=\"text-3xl font-display text-white\" data-kid=\"143\">0.74s</span>\n                        </div>\n                        <div class=\"h-1 w-full bg-white/5 overflow-hidden\" data-kid=\"144\">\n                            <div class=\"h-full w-[94%] bg-[var(--gold)] shadow-[0_0_15px_var(--gold)]\" data-kid=\"145\"></div>\n                        </div>\n                    </div>\n                    <div class=\"space-y-4\" data-kid=\"146\">\n                        <div class=\"flex justify-between items-end\" data-kid=\"147\">\n                            <span class=\"font-mono text-[10px] uppercase tracking-widest text-white/40\" data-kid=\"148\">Speed Index</span>\n                            <span class=\"text-3xl font-display text-white\" data-kid=\"149\">100/100</span>\n                        </div>\n                        <div class=\"h-1 w-full bg-white/5 overflow-hidden\" data-kid=\"150\">\n                            <div class=\"h-full w-full bg-[var(--gold)] shadow-[0_0_15px_var(--gold)]\" data-kid=\"151\"></div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"mt-16 flex items-center gap-6\" data-kid=\"152\">\n                    <div class=\"flex -space-x-3\" data-kid=\"153\">\n                        <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-10 h-10 rounded-full border-2 border-[var(--charcoal)]\" alt=\"User\" data-kid=\"154\">\n                        <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-10 h-10 rounded-full border-2 border-[var(--charcoal)]\" alt=\"User\" data-kid=\"155\">\n                        <img src=\"https://i.pravatar.cc/100?u=3\" class=\"w-10 h-10 rounded-full border-2 border-[var(--charcoal)]\" alt=\"User\" data-kid=\"156\">\n                    </div>\n                    <p class=\"text
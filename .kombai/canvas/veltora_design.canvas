      "html": "<style data-kid=\"0\">\n        @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap');\n        @import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css');\n\n        :root {\n            --gold: #E8A020;\n            --gold-deep: #C47810;\n            --dark: #080808;\n            --charcoal: #111111;\n            --light: #FBFCFD;\n            --glass: rgba(255, 255, 255, 0.03);\n            --glass-border: rgba(255, 255, 255, 0.08);\n            --hairline-gold: rgba(196, 120, 16, 0.22);\n        }\n\n        .font-display { font-family: 'Cormorant Garamond', serif; }\n        .font-body { font-family: 'DM Sans', sans-serif; }\n        .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n        .gold-gradient-text {\n            background: linear-gradient(135deg, var(--gold) 0%, var(--gold-deep) 100%);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n        }\n\n        .glass-card {\n            background: var(--glass);\n            backdrop-filter: blur(20px);\n            -webkit-backdrop-filter: blur(20px);\n            border: 1px solid var(--glass-border);\n        }\n\n        .no-scrollbar::-webkit-scrollbar { display: none; }\n        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n        .grain-overlay {\n            position: absolute;\n            inset: 0;\n            background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.05'/%3E%3C/svg%3E\");\n            pointer-events: none;\n            z-index: 50;\n            opacity: 0.3;\n        }\n\n        .gold-glow {\n            box-shadow: 0 0 40px rgba(196, 120, 16, 0.12);\n        }\n\n        .gold-wash {\n            background: linear-gradient(135deg, rgba(196, 120, 16, 0.08) 0%, transparent 100%);\n        }\n\n        .transition-premium {\n            transition: all 400ms cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        .hairline-gold-border {\n            border: 1px solid var(--hairline-gold);\n        }\n\n        .text-glow-gold {\n            text-shadow: 0 0 20px rgba(232, 160, 32, 0.3);\n        }\n    </style>\n\n<div class=\"font-body text-[#F5F5F5] bg-[var(--dark)] selection:bg-[var(--gold)]/30 overflow-x-hidden relative\" data-kid=\"1\">\n    <div class=\"grain-overlay\" data-kid=\"2\"></div>\n\n    \n    <nav class=\"absolute top-0 left-0 right-0 z-[100] flex items-center justify-between px-8 md:px-16 py-10\" data-kid=\"3\">\n        <div class=\"flex items-center gap-2\" data-kid=\"4\">\n            <span class=\"font-display text-2xl tracking-[0.25em] font-light text-white uppercase\" data-kid=\"5\">\n                <span class=\"text-[var(--gold)]\" data-kid=\"6\">V</span>eltora\n            </span>\n        </div>\n        <div class=\"hidden lg:flex items-center gap-12 font-mono text-[10px] uppercase tracking-[0.3em] text-white/60\" data-kid=\"7\">\n            <a href=\"javascript:void(0)\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"8\">Portfolio</a>\n            <a href=\"javascript:void(0)\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"9\">Services</a>\n            <a href=\"javascript:void(0)\" class=\"hover:text-[var(--gold)] transition-colors\" data-kid=\"10\">Process</a>\n            <a href=\"javascript:void(0)\" class=\"px-6 py-2 border border-[var(--gold)]/30 rounded-full hover:bg-[var(--gold)] hover:text-[var(--dark)] transition-all text-white\" data-kid=\"11\">Start Project</a>\n        </div>\n    </nav>\n\n    \n    <section class=\"relative h-[900px] f
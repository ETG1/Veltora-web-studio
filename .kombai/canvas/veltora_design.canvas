      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;700&family=JetBrains+Mono:wght@400&display=swap');\n\n  :root {\n    --matte-black: #080808;\n    --charcoal: #1E1E2A;\n    --tiger-amber: #E8A020;\n    --cloud-white: #FBFCFD;\n    --text-muted: #A0A0A0;\n  }\n\n  body {\n    font-family: 'DM Sans', sans-serif;\n    background-color: var(--matte-black);\n    color: var(--cloud-white);\n    margin: 0;\n  }\n\n  .font-display {\n    font-family: 'Cormorant Garamond', serif;\n  }\n\n  .font-mono {\n    font-family: 'JetBrains Mono', monospace;\n  }\n\n  .gold-gradient-text {\n    background: linear-gradient(135deg, #E8A020 0%, #C47810 100%);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  .mercury-surface-dark {\n    background-color: var(--matte-black);\n  }\n\n  .mercury-surface-light {\n    background-color: var(--cloud-white);\n    color: var(--matte-black);\n  }\n\n  .charcoal-card {\n    background-color: var(--charcoal);\n    border: 1px solid rgba(232, 160, 32, 0.15);\n  }\n\n  .charcoal-card:hover {\n    border-color: var(--tiger-amber);\n    box-shadow: 0 0 60px rgba(232, 160, 32, 0.08);\n    transform: translateY(-4px);\n  }\n\n  .text-glow-gold {\n    text-shadow: 0 0 20px rgba(232, 160, 32, 0.3);\n  }\n\n  .grain-overlay {\n    position: absolute;\n    inset: 0;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.05'/%3E%3C/svg%3E\");\n    pointer-events: none;\n    z-index: 5;\n    opacity: 0.3;\n  }\n\n  .mask-radial {\n    mask-image: radial-gradient(circle at center, black 0%, transparent 100%);\n  }\n</style>\n\n<div class=\"relative bg-[var(--matte-black)]\" data-kid=\"1\">\n  <div class=\"grain-overlay\" data-kid=\"2\"></div>\n\n\n<nav class=\"absolute top-0 left-0 right-0 z-[100] flex items-center justify-between px-16 py-12 w-full\" data-kid=\"3\">\n  <div class=\"flex items-center gap-3\" data-kid=\"4\">\n    <div class=\"w-10 h-10 rounded-full border border-[var(--tiger-amber)]/50 flex items-center justify-center bg-black/20 backdrop-blur-md\" data-kid=\"5\">\n      <span class=\"text-[var(--tiger-amber)] font-display text-xl\" data-kid=\"6\">V</span>\n    </div>\n    <span class=\"font-display text-2xl tracking-[0.25em] font-light text-white\" data-kid=\"7\">VELTORA</span>\n  </div>\n  <div class=\"hidden md:flex items-center gap-12\" data-kid=\"8\">\n    <a href=\"#\" class=\"text-[10px] font-medium tracking-[0.3em] text-white/60 hover:text-[var(--tiger-amber)] transition-colors uppercase\" data-kid=\"9\">Work</a>\n    <a href=\"#\" class=\"text-[10px] font-medium tracking-[0.3em] text-white/60 hover:text-[var(--tiger-amber)] transition-colors uppercase\" data-kid=\"10\">Services</a>\n    <a href=\"#\" class=\"text-[10px] font-medium tracking-[0.3em] text-white/60 hover:text-[var(--tiger-amber)] transition-colors uppercase\" data-kid=\"11\">Approach</a>\n    <a href=\"#\" class=\"px-10 py-3.5 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm text-[10px] font-bold tracking-[0.3em] hover:bg-white hover:text-black transition-all uppercase\" data-kid=\"12\">Start Project</a>\n  </div>\n</nav>\n\n\n<section class=\"relative h-[900px] flex items-center justify-center overflow-hidden\" data-kid=\"13\">\n  \n  <div class=\"absolute inset-0 z-0\" data-kid=\"14\">\n    <img src=\"https://images.pexels.com/photos/6141905/pexels-photo-6141905.jpeg?auto=compress&cs=tinysrgb&w=1920&q=85\" alt=\"Gold Texture\" class=\"w-full h-full object-cover opacity-40 mix-blend-screen scale-105\" decoding=\"async\" loading=\"lazy\" data-kid=\"15\">\n    \n    <div class=\"absolute inset-0 bg-gradient-to-b from-[var(--matte-black)] via-transparent to-[var(--matte-black)]\" data-kid=\"16\"></div>\n    <div class=\"absolute inset-0 bg-gradient-to-r from-[var(--matte-black)] via-transparent to-[var(--matte-black)] opacity-60\" data-kid=\"17\"></div>\n    <div class=\"absolute inset-0 bg-[var(--matte-black)]/40\" data-kid=\"18\"></div>\n  </div>\n\n  <div class=\"relative z-10 text-center px-6\" data-kid=\"19\">\n    <div class=\"inline-block mb-10 overflow-hidden\" data-kid=\"20\">\n      <p class=\"font-mono text-[var(--tiger-amber)] text-[11px] tracking-[0.5em] uppercase opacity-90 animate-pulse\" data-kid=\"21\">Engineering Premium Digital Architecture</p>\n    </div>\n    <h1 class=\"font-display text-[clamp(4.5rem,11vw,9rem)] leading-[0.85] font-light mb-14 flex flex-col items-center\" data-kid=\"22\">\n      <span class=\"text-white drop-shadow-2xl\" data-kid=\"23\">Precision-built</span>\n      <span class=\"gold-gradient-text italic font-normal text-glow-gold\" data-kid=\"24\">digital experiences</span>\n    </h1>\n    <div class=\"flex flex-col items-center gap-6\" data-kid=\"25\">\n      <p class=\"text-[var(--text-muted)] max-w-lg text-lg font-light leading-relaxed\" data-kid=\"26\">\n        Crafting high-performance digital ecosystems with cinematic aesthetics and architectural precision.\n      </p>\n      <div class=\"mt-4 flex items-center gap-12 border-t border-white/10 pt-10\" data-kid=\"27\">\n        <div class=\"text-center\" data-kid=\"28\">\n          <span class=\"block font-display text-3xl text-[var(--tiger-amber)]\" data-kid=\"29\">8+</span>\n          <span class=\"block text-[8px] font-mono tracking-widest uppercase text-white/40 mt-1\" data-kid=\"30\">Global Clients</span>\n        </div>\n        <div class=\"h-10 w-px bg-white/10\" data-kid=\"31\"></div>\n        <div class=\"text-center\" data-kid=\"32\">\n          <span class=\"block font-display text-3xl text-[var(--tiger-amber)]\" data-kid=\"33\">100%</span>\n          <span class=\"block text-[8px] font-mono tracking-widest uppercase text-white/40 mt-1\" data-kid=\"34\">Delivery rate</span>\n        </div>\n        <div class=\"h-10 w-px bg-white/10\" data-kid=\"35\"></div>\n        <div class=\"text-center\" data-kid=\"36\">\n          <span class=\"block font-display text-3xl text-[var(--tiger-amber)]\" data-kid=\"37\">&lt;2s</span>\n          <span class=\"block text-[8px] font-mono tracking-widest uppercase text-white/40 mt-1\" data-kid=\"38\">Load performance</span>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4\" data-kid=\"39\">\n    <span class=\"text-[8px] font-mono tracking-[0.3em] uppercase text-white/30\" data-kid=\"40\">Scroll</span>\n    <div class=\"w-px h-16 bg-gradient-to-b from-[var(--tiger-amber)] to-transparent\" data-kid=\"41\"></div>\n  </div>\n</section>\n\n\n<section class=\"relative py-32 px-12 bg-[var(--matte-black)]\" data-kid=\"42\">\n  <div class=\"max-w-[1440px] mx-auto\" data-kid=\"43\">\n    <div class=\"mb-24 flex flex-col md:flex-row md:items-end justify-between gap-8\" data-kid=\"44\">\n      <div data-kid=\"45\">\n        <span class=\"font-mono text-[var(--tiger-amber)] text-[10px] tracking-[0.4em] uppercase mb-4 block\" data-kid=\"46\">01 — Services</span>\n        <h2 class=\"font-display text-6xl font-light text-white max-w-xl leading-tight\" data-kid=\"47\">\n          Specialized digital <span class=\"italic\" data-kid=\"48\">craftsmanship</span>.\n        </h2>\n      </div>\n      <p class=\"text-[var(--text-muted)] max-w-xs text-sm leading-relaxed mb-2\" data-kid=\"49\">\n        We specialize in complex web architectures that prioritize speed, security, and editorial design.\n      </p>\n    </div>\n\n    <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"50\">\n      \n      <div class=\"charcoal-card p-10 rounded-[16px] group transition-all duration-500\" data-kid=\"51\">\n        <div class=\"mb-12\" data-kid=\"52\">\n          <span class=\"font-mono text-[var(--tiger-amber)] text-[10px] tracking-[0.4em] uppercase border border-[var(--tiger-amber)]/30 px-3 py-1 rounded-full\" data-kid=\"53\">Forge Tier</span>\n        </div>\n        <h3 class=\"font-display text-3xl text-white mb-4 italic\" data-kid=\"54\">Essential Build</h3>\n        <p class=\"text-[var(--text-muted)] text-sm font-light mb-10 leading-relaxed\" data-kid=\"55\">\n          The foundation for emerging brands. High-performance single-page experiences optimized for conversion.\n        </p>\n        <ul class=\"space-y-4 mb-12\" data-kid=\"56\">\n          <li class=\"flex items-center gap-3 text-sm font-light text-white/70\" data-kid=\"57\">\n            <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--tiger-amber)]\" data-kid=\"58\"></span>\n            Custom UI Design\n          </li>\n          <li class=\"flex items-center gap-3 text-sm font-light text-white/70\" data-kid=\"59\">\n            <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--tiger-amber)]\" data-kid=\"60\"></span>\n            SEO Framework\n          </li>\n          <li class=\"flex items-center gap-3 text-sm font-light text-white/70\" data-kid=\"61\">\n            <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--tiger-amber)]\" data-kid=\"62\"></span>\n            7-Day Delivery\n          </li>\n        </ul>\n        <div class=\"pt-6 border-t border-white/5\" data-kid=\"63\">\n          <span class=\"font-display text-2xl text-[var(--tiger-amber)]\" data-kid=\"64\">R3,500 <span class=\"text-xs font-sans text-white/40 italic\" data-kid=\"65\">Setup</span></span>\n        </div>\n      </div>\n\n      \n      <div class=\"charcoal-card p-10 rounded-[16px] group transition-all duration-500 border-[var(--tiger-amber)]/50 bg-gradient-to-br from-[var(--charcoal)] to-[#252535] relative overflow-hidden\" data-kid=\"66\">\n        <div class=\"absolute top-0 right-0 w-32 h-32 bg-[var(--tiger-amber)]/5 blur-3xl rounded-full -mr-16 -mt-16 group-hover:bg-[var(--tiger-amber)]/10 transition-all duration-700\" data-kid=\"67\"></div>\n        <div class=\"mb-12 flex justify-between items-start relative z-10\" data-kid=\"68\">\n          <span class=\"font-mono text-[var(--tiger-amber)] text-[10px] tracking-[0.4em] uppercase border border-[var(--tiger-amber)] px-3 py-1 rounded-full bg-[var(--tiger-amber)] text-black font-bold\" data-kid=\"69\">Velocity Tier</span>\n          <span class=\"text-[var(--tiger-amber)] text-[10px] font-mono tracking-widest uppercase\" data-kid=\"70\">Popular Choice</span>\n        </div>\n        <h3 class=\"font-display text-3xl text-white mb-4 italic\" data-kid=\"71\">Strategic Scale</h3>\n        <p class=\"text-[var(--text-muted)] text-sm font-light mb-10 leading-relaxed\" data-kid=\"72\">\n          Advanced architectures for established businesses. Multi-page systems with deep analytical integration.\n        </p>\n        <ul class=\"space-y-4 mb-12\" data-kid=\"73\">\n          <li class=\"flex items-center gap-3 text-sm font-light text-white/70\" data-kid=\"74\">\n            <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--tiger-amber)]\" data-kid=\"75\"></span>\n            Dynamic Content Management\n          </li>\n          <li class=\"flex items-center gap-3 text-sm font-light text-white/70\" data-kid=\"76\">\n            <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--tiger-amber)]\" data-kid=\"77\"></span>\n            Speed Optimization Audit\n          </li>\n          <li class=\"flex items-center gap-3 text-sm font-light text-white/70\" data-kid=\"78\">\n            <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--tiger-amber)]\" data-kid=\"79\"></span>\n            14-Day Delivery\n          </li>\n        </ul>\n        <div class=\"pt-6 border-t border-white/5\" data-kid=\"80\">\n          <span class=\"font-display text-2xl text-[var(--tiger-amber)]\" data-kid=\"81\">R6,500 <span class=\"text-xs font-sans text-white/40 italic\" data-kid=\"82\">Setup</span></span>\n        </div>\n      </div>\n\n      \n      <div class=\"charcoal-card p-10 rounded-[16px] group transition-all duration-500\" data-kid=\"83\">\n        <div class=\"mb-12\" data-kid=\"84\">\n          <span class=\"font-mono text-[var(--tiger-amber)] text-[10px] tracking-[0.4em] uppercase border border-[var(--tiger-amber)]/30 px-3 py-1 rounded-full\" data-kid=\"85\">Apex Tier</span>\n        </div>\n        <h3 class=\"font-display text-3xl text-white mb-4 italic\" data-kid=\"86\">Enterprise Custom</h3>\n        <p class=\"text-[var(--text-muted)] text-sm font-light mb-10 leading-relaxed\" data-kid=\"87\">\n          Bespoke digital products. Full-stack applications, e-commerce engines, and premium custom features.\n        </p>\n        <ul class=\"space-y-4 mb-12\" data-kid=\"88\">\n          <li class=\"flex items-center gap-3 text-sm font-light text-white/70\" data-kid=\"89\">\n            <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--tiger-amber)]\" data-kid=\"90\"></span>\n            Database Integration\n          </li>\n          <li class=\"flex items-center gap-3 text-sm font-light text-white/70\" data-kid=\"91\">\n            <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--tiger-amber)]\" data-kid=\"92\"></span>\n            Authentication Systems\n          </li>\n          <li class=\"flex items-center gap-3 text-sm font-light text-white/70\" data-kid=\"93\">\n            <span class=\"w-1.5 h-1.5 rounded-full bg-[var(--tiger-amber)]\" data-kid=\"94\"></span>\n            28-Day Delivery\n          </li>\n        </ul>\n        <div class=\"pt-6 border-t border-white/5\" data-kid=\"95\">\n          <span class=\"font-display text-2xl text-[var(--tiger-amber)]\" data-kid=\"96\">R12,000 <span class=\"text-xs font-sans text-white/40 italic\" data-kid=\"97\">Setup</span></span>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"mercury-surface-light py-64 px-12 overflow-hidden relative border-y border-black/5\" data-kid=\"98\">\n  \n  <div class=\"absolute left-16 top-1/2 -translate-y-1/2 hidden xl:flex flex-col gap-2 opacity-10\" data-kid=\"99\">\n    <div class=\"w-1.5 h-1.5 rounded-full bg-black\" data-kid=\"100\"></div>\n    <div class=\"w-1.5 h-1.5 rounded-full bg-black\" data-kid=\"101\"></div>\n    <div class=\"w-1.5 h-48 border-l border-black\" data-kid=\"102\"></div>\n  </div>\n\n  <div class=\"max-w-[950px] mx-auto text-center relative z-10\" data-kid=\"103\">\n    \n    <div class=\"absolute -top-40 left-1/2 -translate-x-1/2 font-display text-[22rem] text-black/[0.01] select-none pointer-events-none italic leading-none\" data-kid=\"104\">\n      Legacy\n    </div>\n    \n    <span class=\"font-mono text-[11px] tracking-[0.6em] uppercase mb-16 block text-black/40\" data-kid=\"105\">Client Perspective</span>\n    <blockquote class=\"font-display text-[clamp(2.25rem,5vw,3.75rem)] leading-[1.15] font-light mb-20 italic text-black tracking-tight drop-shadow-sm\" data-kid=\"106\">\n      \"Working with Veltora felt different. Fast, professional, and the final product looked better than I imagined. They didn't just build a site; they crafted a digital home for my brand.\"\n    </blockquote>\n    <div class=\"flex flex-col items-center\" data-kid=\"107\">\n      <div class=\"w-12 h-px bg-black/20 mb-6\" data-kid=\"108\"></div>\n      <cite class=\"not-italic\" data-kid=\"109\">\n        <span class=\"block font-sans font-bold text-sm tracking-widest uppercase\" data-kid=\"110\">EAGLE AIR FLIGHT SCHOOL</span>\n        <span class=\"block font-mono text-[10px] tracking-widest text-black/40 mt-1 uppercase\" data-kid=\"111\">Johannesburg, South Africa</span>\n      </cite>\n    </div>\n  </div>\n\n  \n  <div class=\"mt-40 max-w-[1440px] mx-auto pt-24 border-t border-black/[0.08]\" data-kid=\"112\">\n    <div class=\"flex flex-wrap items-center justify-center gap-x-24 gap-y-12 opacity-30 grayscale hover:grayscale-0 transition-all duration-700\" data-kid=\"113\">\n      <span class=\"font-display text-2xl tracking-[0.1em] font-semibold\" data-kid=\"114\">ELI TWO</span>\n      <span class=\"font-display text-2xl tracking-[0.1em] font-semibold\" data-kid=\"115\">HOTEL NINE</span>\n      <span class=\"font-display text-2xl tracking-[0.1em] font-semibold\" data-kid=\"116\">TOGB AGENCY</span>\n      <span class=\"font-display text-2xl tracking-[0.1em] font-semibold\" data-kid=\"117\">LM MOTORS</span>\n      <span class=\"font-display text-2xl tracking-[0.1em] font-semibold\" data-kid=\"118\">TABERNACLE</span>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"bg-[var(--matte-black)] py-56\" data-kid=\"119\">\n  <div class=\"px-16 mb-32 flex flex-col md:flex-row items-end justify-between border-l border-[var(--tiger-amber)]/20 ml-16 pl-12\" data-kid=\"120\">\n    <div data-kid=\"121\">\n      <span class=\"font-mono text-[var(--tiger-amber)] text-[11px] tracking-[0.6em] uppercase mb-8 block\" data-kid=\"122\">02 — Works Archive</span>\n      <h2 class=\"font-display text-[clamp(3.5rem,7vw,6rem)] font-light text-white leading-[1] mb-4\" data-kid=\"123\">\n        Atmospheric <span class=\"italic text-glow-gold\" data-kid=\"124\">Portfolio</span>.\n      </h2>\n      <p class=\"text-[var(--text-muted)] text-sm font-light max-w-sm\" data-kid=\"125\">Selected architectural builds for global leaders in aviation, hospitality, and luxury retail.</p>\n    </div>\n    <div class=\"hidden md:flex flex-col items-end pb-4\" data-kid=\"126\">\n      <a href=\"#\" class=\"group flex items-center gap-6\" data-kid=\"127\">\n        <span class=\"text-[10px] font-mono tracking-[0.4em] uppercase text-white/40 group-hover:text-white transition-colors\" data-kid=\"128\">Browse Archive</span>\n        <div class=\"w-12 h-12 rounded-full border border-white/10 flex items-center justify-center group-hover:border-[var(--tiger-amber)] transition-all\" data-kid=\"129\">\n          <svg class=\"w-5 h-5 text-[var(--tiger-amber)]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"130\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\" data-kid=\"131\"></path></svg>\n        </div>\n      </a>\n    </div>\n  </div>\n\n  <div class=\"space-y-48 px-16\" data-kid=\"132\">\n    \n    <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 items-center\" data-kid=\"133\">\n      <div class=\"lg:col-span-7 relative h-[700px] overflow-hidden rounded-[2px] group\" data-kid=\"134\">\n        <img src=\"https://images.pexels.com/photos/7031406/pexels-photo-7031406.jpeg?auto=compress&cs=tinysrgb&w=1200&q=90\" alt=\"Eagle Air\" class=\"w-full h-full object-cover transition-transform duration-[2000ms] group-hover:scale-105\" decoding=\"async\" loading=\"lazy\" data-kid=\"135\">\n        <div class=\"absolute inset-0 bg-black/10 group-hover:bg-black/0 transition-all duration-1000\" data-kid=\"136\"></div>\n      </div>\n      <div class=\"lg:col-span-5 pr-12\" data-kid=\"137\">\n        <span class=\"font-mono text-[10px] tracking-[0.5em] uppercase text-[var(--tiger-amber)] mb-8 block opacity-80\" data-kid=\"138\">01 / Aviation Architecture</span>\n        <h3 class=\"font-display text-6xl text-white mb-10 leading-[1.1] italic font-light\" data-kid=\"139\">Eagle Air <br data-kid=\"140\">Flight School</h3>\n        <p class=\"text-white/40 text-lg font-light leading-relaxed mb-12 italic\" data-kid=\"141\">\n          \"The precision in layout reflects our cockpit checklists. Every pixel serves a purpose.\"\n        </p>\n        <button class=\"px-12 py-5 rounded-full border border-white/20 text-[10px] font-bold tracking-[0.4em] text-white hover:bg-white hover:text-black transition-all uppercase\" data-kid=\"142\">View Project</button>\n      </div>\n    </div>\n\n    \n    <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 items-center\" data-kid=\"143\">\n      <div class=\"lg:col-span-5 lg:order-1 order-2 pl-12\" data-kid=\"144\">\n        <span class=\"font-mono text-[10px] tracking-[0.5em] uppercase text-[var(--tiger-amber)] mb-8 block opacity-80\" data-kid=\"145\">02 / Hospitality Boutique</span>\n        <h3 class=\"font-display text-6xl text-white mb-10 leading-[1.1] italic font-light\" data-kid=\"146\">Hotel Nine <br data-kid=\"147\">Interiors</h3>\n        <p class=\"text-white/40 text-lg font-light leading-relaxed mb-12 italic\" data-kid=\"148\">\n          Editorial-grade digital spaces that mirror the tactile luxury of a five-star suite.\n        </p>\n        <button class=\"px-12 py-5 rounded-full border border-white/20 text-[10px] font-bold tracking-[0.4em] text-white hover:bg-white hover:text-black transition-all uppercase\" data-kid=\"149\">View Project</button>\n      </div>\n      <div class=\"lg:col-span-7 lg:order-2 order-1 relative h-[700px] overflow-hidden rounded-[2px] group\" data-kid=\"150\">\n        <img src=\"https://images.pexels.com/photos/2507007/pexels-photo-2507007.jpeg?auto=compress&cs=tinysrgb&w=1200&q=90\" alt=\"Hotel Nine\" class=\"w-full h-full object-cover transition-transform duration-[2000ms] group-hover:scale-105\" decoding=\"async\" loading=\"lazy\" data-kid=\"151\">\n        <div class=\"absolute inset-0 bg-black/10 group-hover:bg-black/0 transition-all duration-1000\" data-kid=\"152\"></div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"bg-[var(--matte-black)] py-40 border-t border-white/5 relative overflow-hidden\" data-kid=\"153\">\n  \n  <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[var(--tiger-amber)]/10 blur-[150px] rounded-full pointer-events-none\" data-kid=\"154\"></div>\n  \n  <div class=\"relative z-10 max-w-4xl mx-auto px-12 text-center\" data-kid=\"155\">\n    <span class=\"font-mono text-[var(--tiger-amber)] text-[10px] tracking-[0.4em] uppercase mb-8 block\" data-kid=\"156\">03 — Conclusion</span>\n    <h2 class=\"font-display text-[clamp(3.5rem,8vw,6.5rem)] font-light text-white mb-12 leading-[0.9]\" data-kid=\"157\">Ready to refine your <span class=\"italic gold-gradient-text drop-shadow-2xl\" data-kid=\"158\">presence?</span></h2>\n    <p class=\"text-[var(--text-muted)] text-xl font-light leading-relaxed mb-20 max-w-2xl mx-auto\" data-kid=\"159\">\n      Whether you're scaling an enterprise or launching a boutique brand, we bring architectural precision to your digital storefront.\n    </p>\n    <a href=\"#\" class=\"inline-block px-14 py-6 bg-[var(--tiger-amber)] text-black font-bold tracking-[0.3em] rounded-full text-xs hover:bg-white hover:text-black hover:scale-105 transition-all duration-500 shadow-2xl\" data-kid=\"160\">START YOUR PROJECT</a>\n    \n    <div class=\"mt-32 flex flex-wrap justify-center gap-x-20 gap-y-10 pt-20 border-t border-white/5\" data-kid=\"161\">\n      <div class=\"text-left\" data-kid=\"162\">\n        <span class=\"block text-[9px] font-mono tracking-[0.3em] uppercase text-white/30 mb-4\" data-kid=\"163\">Direct</span>\n        <a href=\"mailto:hello@veltora.co.za\" class=\"text-sm font-light text-white hover:text-[var(--tiger-amber)] transition-colors\" data-kid=\"164\">hello@veltora.co.za</a>\n      </div>\n      <div class=\"text-left\" data-kid=\"165\">\n        <span class=\"block text-[9px] font-mono tracking-[0.3em] uppercase text-white/30 mb-4\" data-kid=\"166\">Connect</span>\n        <a href=\"#\" class=\"text-sm font-light text-white hover:text-[var(--tiger-amber)] transition-colors\" data-kid=\"167\">+27 82 000 0000</a>\n      </div>\n      <div class=\"text-left\" data-kid=\"168\">\n        <span class=\"block text-[9px] font-mono tracking-[0.3em] uppercase text-white/30 mb-4\" data-kid=\"169\">Studio</span>\n        <span class=\"text-sm font-light text-white\" data-kid=\"170\">Pretoria, ZA</span>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<footer class=\"bg-[var(--matte-black)] py-16 px-16 border-t border-white/5 relative overflow-hidden\" data-kid=\"171\">\n  <div class=\"max-w-[1440px] mx-auto flex flex-col md:flex-row justify-between items-center gap-12 relative z-10\" data-kid=\"172\">\n    <div class=\"flex items-center gap-8\" data-kid=\"173\">\n      <span class=\"font-display text-2xl tracking-[0.3em] font-light text-white/70\" data-kid=\"174\">VELTORA</span>\n      <span class=\"text-[var(--text-muted)] text-[9px] font-mono tracking-[0.4em] uppercase pt-1\" data-kid=\"175\">© 2025 ALL RIGHTS RESERVED.</span>\n    </div>\n    <div class=\"flex items-center gap-10\" data-kid=\"176\">\n      <a href=\"#\" class=\"text-[9px] font-mono tracking-[0.4em] uppercase text-white/40 hover:text-white transition-colors\" data-kid=\"177\">IG</a>\n      <a href=\"#\" class=\"text-[9px] font-mono tracking-[0.4em] uppercase text-white/40 hover:text-white transition-colors\" data-kid=\"178\">LI</a>\n      <a href=\"#\" class=\"text-[9px] font-mono tracking-[0.4em] uppercase text-white/40 hover:text-white transition-colors\" data-kid=\"179\">TW</a>\n    </div>\n    <div class=\"flex items-center gap-4\" data-kid=\"180\">\n      <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--tiger-amber)]\" data-kid=\"181\"></div>\n      <span class=\"text-[9px] font-mono tracking-[0.4em] uppercase text-[var(--tiger-amber)]\" data-kid=\"182\">Pan-African Design</span>\n    </div>\n  </div>\n  \n  \n  <div class=\"mt-24 text-center overflow-hidden opacity-[0.03] select-none pointer-events-none\" data-kid=\"183\">\n    <span class=\"font-display text-[10vw] leading-none tracking-[-0.05em] block\" data-kid=\"184\">VELTORA WEB STUDIO</span>\n  </div>\n</footer>\n</div>\n",

      "html": "\n<div class=\"bg-[#080808] text-[#F5F5F5] font-['DM_Sans',sans-serif] selection:bg-[#C47810]/30 selection:text-white\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@400&display=swap');\n\n    .font-display { font-family: 'Cormorant Garamond', serif; }\n    .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n    .glass {\n      background: rgba(255, 255, 255, 0.03);\n      backdrop-filter: blur(12px);\n      -webkit-backdrop-filter: blur(12px);\n      border: 1px solid rgba(255, 255, 255, 0.1);\n    }\n\n    .glass-light {\n      background: rgba(255, 255, 255, 0.6);\n      backdrop-filter: blur(8px);\n      -webkit-backdrop-filter: blur(8px);\n      border: 1px solid rgba(255, 255, 255, 0.2);\n    }\n\n    .gold-wash {\n      background: linear-gradient(135deg, rgba(196, 120, 16, 0.15) 0%, transparent 100%);\n    }\n\n    .gold-glow {\n      box-shadow: 0 0 30px rgba(196, 120, 16, 0.1);\n    }\n\n    .transition-premium {\n      transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);\n    }\n\n    .kanji-bg {\n      font-family: 'Cormorant Garamond', serif;\n      user-select: none;\n      pointer-events: none;\n    }\n\n    /* Hide scrollbar for clean horizontal look */\n    .no-scrollbar::-webkit-scrollbar { display: none; }\n    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n    .hairline-dark { border-color: rgba(255, 255, 255, 0.22); }\n    .hairline-light { border-color: rgba(0, 0, 0, 0.1); }\n  </style>\n\n  \n  <nav class=\"absolute top-0 left-0 right-0 z-50 flex justify-between items-center px-8 py-6\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2\" data-kid=\"3\">\n      <span class=\"font-display text-2xl tracking-[0.2em] font-light text-white\" data-kid=\"4\"><span class=\"text-[#C47810]\" data-kid=\"5\">V</span>ELTORA</span>\n    </div>\n    <div class=\"hidden md:flex gap-10 items-center\" data-kid=\"6\">\n      <a href=\"#\" class=\"text-[10px] font-mono tracking-widest text-[#A0A0A0] hover:text-[#C47810] transition-premium\" data-kid=\"7\">WORK</a>\n      <a href=\"#\" class=\"text-[10px] font-mono tracking-widest text-[#A0A0A0] hover:text-[#C47810] transition-premium\" data-kid=\"8\">STUDIO</a>\n      <a href=\"#\" class=\"text-[10px] font-mono tracking-widest text-[#A0A0A0] hover:text-[#C47810] transition-premium\" data-kid=\"9\">PROCESS</a>\n      <a href=\"#\" class=\"px-5 py-2 glass text-[10px] font-mono tracking-widest hover:border-[#C47810]/50 transition-premium\" data-kid=\"10\">INQUIRE</a>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative h-[820px] flex flex-col items-center justify-center overflow-hidden bg-[#080808]\" data-kid=\"11\">\n    \n    <div class=\"absolute top-1/4 left-0 w-32 h-[1px] bg-linear-to-r from-[#C47810]/40 to-transparent\" data-kid=\"12\"></div>\n    <div class=\"absolute bottom-1/4 right-0 w-48 h-[1px] bg-linear-to-l from-[#C47810]/30 to-transparent\" data-kid=\"13\"></div>\n\n    \n    <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"14\">\n      <span class=\"kanji-bg text-[850px] leading-none text-[#C47810] opacity-[0.02]\" data-kid=\"15\">虎</span>\n    </div>\n\n    <div class=\"relative z-10 max-w-[900px] w-full px-6 text-center\" data-kid=\"16\">\n      <div class=\"mb-6 flex justify-center\" data-kid=\"17\">\n         <span class=\"px-3 py-1 glass text-[10px] font-mono tracking-widest text-[#C47810]\" data-kid=\"18\">EST. 2025</span>\n      </div>\n      <h1 class=\"font-display text-7xl md:text-8xl font-light leading-[0.9] tracking-tight mb-8\" data-kid=\"19\">\n        Precision-built<br data-kid=\"20\">\n        <span class=\"italic font-light\" data-kid=\"21\">digital craft.</span>\n      </h1>\n      <p class=\"text-[#A0A0A0] max-w-lg mx-auto mb-12 text-lg font-light leading-relaxed\" data-kid=\"22\">\n        We architect high-performance interfaces for brands that value aesthetic excellence and technical rigor.\n      </p>\n\n      \n      <div class=\"flex max-w-md mx-auto p-1.5 glass rounded-full overflow-hidden group/input transition-premium hover:border-[#C47810]/30\" data-kid=\"23\">\n        <input type=\"email\" placeholder=\"Your studio email\" class=\"flex-1 bg-transparent px-6 py-3 text-sm focus:outline-hidden placeholder:text-[#555555] font-light\" data-kid=\"24\">\n        <button class=\"bg-[#C47810] hover:bg-[#E8A020] text-white px-8 py-3 rounded-full text-[10px] font-mono tracking-[0.2em] transition-premium shadow-[0_0_20px_rgba(196,120,16,0.2)] hover:shadow-[0_0_30px_rgba(196,120,16,0.4)]\" data-kid=\"25\">\n          CONNECT\n        </button>\n      </div>\n    </div>\n\n    \n    <div class=\"absolute bottom-12 flex flex-col items-center gap-4\" data-kid=\"26\">\n      <span class=\"text-[9px] font-mono tracking-[0.4em] text-[#555555]\" data-kid=\"27\">SCROLL TO EXPLORE</span>\n      <div class=\"w-[1px] h-16 bg-linear-to-b from-[#C47810]/50 to-transparent\" data-kid=\"28\"></div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-12 md:px-24 bg-[#080808] border-t hairline-dark\" data-kid=\"29\">\n    <div class=\"max-w-[1200px] mx-auto grid md:grid-cols-2 gap-24 items-center\" data-kid=\"30\">\n      \n      <div data-kid=\"31\">\n        <span class=\"text-[10px] font-mono tracking-[0.3em] text-[#C47810] block mb-6\" data-kid=\"32\">01 — CORE RIGOR</span>\n        <h2 class=\"font-display text-5xl font-light leading-tight mb-8\" data-kid=\"33\">\n          The intersection of <br data-kid=\"34\">\n          <span class=\"italic\" data-kid=\"35\">art & arithmetic.</span>\n        </h2>\n        <p class=\"text-[#A0A0A0] text-lg font-light leading-relaxed mb-10\" data-kid=\"36\">\n          Our approach transcends mere aesthetic. We write lean, performant code that honors the design intent while pushing the boundaries of what is possible on the modern web.\n        </p>\n        <div class=\"grid grid-cols-2 gap-8\" data-kid=\"37\">\n          <div data-kid=\"38\">\n            <h4 class=\"font-mono text-[10px] tracking-widest text-white mb-2 uppercase\" data-kid=\"39\">Performance</h4>\n            <p class=\"text-sm text-[#555555]\" data-kid=\"40\">Sub-200ms interactions and flawless LCP scores.</p>\n          </div>\n          <div data-kid=\"41\">\n            <h4 class=\"font-mono text-[10px] tracking-widest text-white mb-2 uppercase\" data-kid=\"42\">Scalability</h4>\n            <p class=\"text-sm text-[#555555]\" data-kid=\"43\">Systems built to evolve with your project roadmap.</p>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"space-y-8 relative\" data-kid=\"44\">\n        \n        <div class=\"absolute -left-12 top-1/2 -translate-y-1/2 w-px h-64 bg-linear-to-b from-transparent via-[#C47810]/30 to-transparent\" data-kid=\"45\"></div>\n\n        \n        <div class=\"glass rounded-2xl p-8 transform rotate-1 gold-glow relative overflow-hidden group transition-premium hover:rotate-0\" data-kid=\"46\">\n          <div class=\"absolute inset-0 gold-wash opacity-0 group-hover:opacity-100 transition-opacity duration-300\" data-kid=\"47\"></div>\n          <div class=\"relative z-10\" data-kid=\"48\">\n            <div class=\"flex items-center justify-between mb-8\" data-kid=\"49\">\n              <div class=\"flex gap-2\" data-kid=\"50\">\n                <div class=\"w-2.5 h-2.5 rounded-full bg-[#C47810]/40\" data-kid=\"51\"></div>\n                <div class=\"w-2.5 h-2.5 rounded-full bg-white/10\" data-kid=\"52\"></div>\n                <div class=\"w-2.5 h-2.5 rounded-full bg-white/10\" data-kid=\"53\"></div>\n              </div>\n              <span class=\"text-[9px] font-mono text-[#555555] tracking-widest uppercase\" data-kid=\"54\">main.ts</span>\n            </div>\n            <pre class=\"font-mono text-[11px] text-[#A0A0A0] leading-loose\" data-kid=\"55\">\n<span class=\"text-[#C47810]\">import</span> { <span class=\"text-white\">Craft</span> } <span class=\"text-[#C47810]\">from</span> <span class=\"text-white\">'@veltora/core'</span>;\n\n<span class=\"text-[#C47810]\">export default</span> <span class=\"text-white\">Craft</span>({\n  aesthetic: <span class=\"text-white\">'Cinematic'</span>,\n  rigor: <span class=\"text-white\">true</span>,\n  output: () => <span class=\"text-white\">'Excellence'</span>\n});</pre>\n          </div>\n        </div>\n\n        \n        <div class=\"glass rounded-2xl p-10 transform -rotate-2 gold-glow relative overflow-hidden group transition-premium hover:rotate-0\" data-kid=\"56\">\n          <div class=\"absolute inset-0 gold-wash opacity-0 group-hover:opacity-100 transition-opacity duration-300\" data-kid=\"57\"></div>\n          <div class=\"relative z-10 flex justify-between items-center\" data-kid=\"58\">\n            <div data-kid=\"59\">\n              <span class=\"font-mono text-[10px] tracking-[0.3em] text-[#C47810] block mb-2\" data-kid=\"60\">FIDELITY INDEX</span>\n              <span class=\"text-5xl font-display italic font-light\" data-kid=\"61\">99.8<span class=\"text-xl non-italic ml-1 opacity-40\" data-kid=\"62\">%</span></span>\n            </div>\n            <div class=\"relative flex items-center justify-center\" data-kid=\"63\">\n              <svg class=\"w-24 h-24 transform -rotate-90\" data-kid=\"64\">\n                <circle cx=\"48\" cy=\"48\" r=\"40\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"transparent\" class=\"text-white/5\" data-kid=\"65\"></circle>\n                <circle cx=\"48\" cy=\"48\" r=\"40\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"transparent\" stroke-dasharray=\"251.2\" stroke-dashoffset=\"50.24\" class=\"text-[#C47810]\" data-kid=\"66\"></circle>\n              </svg>\n              <div class=\"absolute font-mono text-[10px] text-white\" data-kid=\"67\">PRO</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative py-48 overflow-hidden bg-white text-black border-t hairline-dark\" data-kid=\"68\">\n    \n    <div class=\"absolute inset-0 w-full h-full\" data-kid=\"69\">\n      <img src=\"https://images.unsplash.com/photo-1663811396522-cab0eb7b501e?auto=format&w=2000&q=80&fit=crop\" alt=\"Architecture\" class=\"w-full h-full object-cover opacity-15 pointer-events-none grayscale brightness-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"70\">\n    </div>\n    \n    \n    <div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-[1px] h-32 bg-linear-to-b from-black/20 to-transparent\" data-kid=\"71\"></div>\n\n    <div class=\"relative z-10 px-12 md:px-24 mb-24\" data-kid=\"72\">\n      <div class=\"flex flex-col md:flex-row md:items-end justify-between gap-8\" data-kid=\"73\">\n        <div data-kid=\"74\">\n          <span class=\"text-[10px] font-mono tracking-[0.4em] text-[#C47810] block mb-6 uppercase\" data-kid=\"75\">02 — Selected Works</span>\n          <h2 class=\"font-display text-6xl md:text-7xl font-light leading-[0.85]\" data-kid=\"76\">\n            Editorial <br data-kid=\"77\">\n            <span class=\"italic font-light\" data-kid=\"78\">Showcase.</span>\n          </h2>\n        </div>\n        <p class=\"max-w-xs text-sm font-light text-black/60 leading-relaxed mb-2\" data-kid=\"79\">\n          A curation of digital environments where precision meets purpose. Each project is a bespoke architectural feat.\n        </p>\n      </div>\n    </div>\n\n    \n    <div class=\"relative z-10 flex gap-12 px-12 md:px-24 overflow-x-auto no-scrollbar pb-10\" data-kid=\"80\">\n      \n      <div class=\"shrink-0 w-[500px] group cursor-pointer\" data-kid=\"81\">\n        <div class=\"aspect-[4/5] bg-neutral-100 rounded-sm overflow-hidden border border-black/5 mb-8 transition-premium group-hover:shadow-2xl group-hover:-translate-y-2 relative\" data-kid=\"82\">\n           <img src=\"https://images.unsplash.com/photo-1663811396522-cab0eb7b501e?auto=format&w=800&q=80&fit=crop&crop=faces\" class=\"w-full h-full object-cover opacity-60 mix-blend-multiply transition-premium group-hover:scale-105 group-hover:opacity-100\" alt=\"Eagle Air\" decoding=\"async\" loading=\"lazy\" data-kid=\"83\">\n           <div class=\"absolute bottom-8 left-8\" data-kid=\"84\">\n             <span class=\"font-display text-7xl text-black/5 leading-none\" data-kid=\"85\">01</span>\n           </div>\n           <div class=\"absolute inset-0 border-[20px] border-white/40 pointer-events-none opacity-0 group-hover:opacity-100 transition-premium\" data-kid=\"86\"></div>\n        </div>\n        <div class=\"flex justify-between items-start px-2\" data-kid=\"87\">\n          <div data-kid=\"88\">\n            <h3 class=\"font-display text-3xl font-light mb-2\" data-kid=\"89\">Eagle Air School</h3>\n            <p class=\"text-[11px] font-mono text-black/40 tracking-widest uppercase\" data-kid=\"90\">Education / Performance Systems</p>\n          </div>\n          <div class=\"flex flex-col items-end\" data-kid=\"91\">\n            <span class=\"text-[#C47810] font-mono text-xs mb-1\" data-kid=\"92\">2024</span>\n            <span class=\"w-8 h-[1px] bg-[#C47810]/40\" data-kid=\"93\"></span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"shrink-0 w-[500px] group cursor-pointer\" data-kid=\"94\">\n        <div class=\"aspect-[4/5] bg-neutral-100 rounded-sm overflow-hidden border border-black/5 mb-8 transition-premium group-hover:shadow-2xl group-hover:-translate-y-2 relative\" data-kid=\"95\">\n           <img src=\"https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover opacity-60 mix-blend-multiply transition-premium group-hover:scale-105 group-hover:opacity-100\" alt=\"Hotel Nine\" decoding=\"async\" loading=\"lazy\" data-kid=\"96\">\n           <div class=\"absolute bottom-8 left-8\" data-kid=\"97\">\n             <span class=\"font-display text-7xl text-black/5 leading-none\" data-kid=\"98\">02</span>\n           </div>\n           <div class=\"absolute inset-0 border-[20px] border-white/40 pointer-events-none opacity-0 group-hover:opacity-100 transition-premium\" data-kid=\"99\"></div>\n        </div>\n        <div class=\"flex justify-between items-start px-2\" data-kid=\"100\">\n          <div data-kid=\"101\">\n            <h3 class=\"font-display text-3xl font-light mb-2\" data-kid=\"102\">Hotel Nine</h3>\n            <p class=\"text-[11px] font-mono text-black/40 tracking-widest uppercase\" data-kid=\"103\">Hospitality / Luxury Experience</p>\n          </div>\n          <div class=\"flex flex-col items-end\" data-kid=\"104\">\n            <span class=\"text-[#C47810] font-mono text-xs mb-1\" data-kid=\"105\">2024</span>\n            <span class=\"w-8 h-[1px] bg-[#C47810]/40\" data-kid=\"106\"></span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"shrink-0 w-[500px] group cursor-pointer\" data-kid=\"107\">\n        <div class=\"aspect-[4/5] bg-neutral-100 rounded-sm overflow-hidden border border-black/5 mb-8 transition-premium group-hover:shadow-2xl group-hover:-translate-y-2 relative\" data-kid=\"108\">\n           <img src=\"https://images.unsplash.com/photo-1593642532400-2682810df593?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover opacity-60 mix-blend-multiply transition-premium group-hover:scale-105 group-hover:opacity-100\" alt=\"Tennis\" decoding=\"async\" loading=\"lazy\" data-kid=\"109\">\n           <div class=\"absolute bottom-8 left-8\" data-kid=\"110\">\n             <span class=\"font-display text-7xl text-black/5 leading-none\" data-kid=\"111\">03</span>\n           </div>\n           <div class=\"absolute inset-0 border-[20px] border-white/40 pointer-events-none opacity-0 group-hover:opacity-100 transition-premium\" data-kid=\"112\"></div>\n        </div>\n        <div class=\"flex justify-between items-start px-2\" data-kid=\"113\">\n          <div data-kid=\"114\">\n            <h3 class=\"font-display text-3xl font-light mb-2\" data-kid=\"115\">Tennis Whisperer</h3>\n            <p class=\"text-[11px] font-mono text-black/40 tracking-widest uppercase\" data-kid=\"116\">E-Commerce / Global Sports</p>\n          </div>\n          <div class=\"flex flex-col items-end\" data-kid=\"117\">\n            <span class=\"text-[#C47810] font-mono text-xs mb-1\" data-kid=\"118\">2023</span>\n            <span class=\"w-8 h-[1px] bg-[#C47810]/40\" data-kid=\"119\"></span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-40 px-12 md:px-24 bg-[#080808] border-t hairline-dark relative\" data-kid=\"120\">\n    <div class=\"max-w-[1200px] mx-auto grid md:grid-cols-2 gap-24 items-center\" data-kid=\"121\">\n      <div class=\"relative\" data-kid=\"122\">\n        <div class=\"absolute -left-12 top-0 w-[1px] h-full bg-linear-to-b from-[#C47810] via-transparent to-transparent\" data-kid=\"123\"></div>\n        <span class=\"text-[10px] font-mono tracking-[0.4em] text-[#C47810] block mb-8 uppercase\" data-kid=\"124\">03 — The Philosophy</span>\n        <h2 class=\"font-display text-6xl font-light leading-[0.9] text-white mb-10\" data-kid=\"125\">\n          One person. <br data-kid=\"126\">\n          <span class=\"italic\" data-kid=\"127\">Full studio output.</span>\n        </h2>\n        <p class=\"text-[#A0A0A0] text-xl font-light leading-relaxed mb-8\" data-kid=\"128\">\n          I built Veltora because I saw too many businesses with great ideas but weak digital presence. I do both sides: write every line of code and design every pixel.\n        </p>\n        <div class=\"flex gap-4\" data-kid=\"129\">\n          <div class=\"px-4 py-2 glass rounded-full text-[10px] font-mono tracking-widest text-white\" data-kid=\"130\">CERTIFIED ALX ENG</div>\n          <div class=\"px-4 py-2 glass rounded-full text-[10px] font-mono tracking-widest text-white\" data-kid=\"131\">DESIGN-LED CODE</div>\n        </div>\n      </div>\n      <div class=\"grid grid-cols-2 gap-4\" data-kid=\"132\">\n        <div class=\"glass p-8 rounded-2xl border-white/5 group hover:border-[#C47810]/20 transition-premium\" data-kid=\"133\">\n          <span class=\"text-[10px] font-mono text-[#555555] block mb-4 uppercase\" data-kid=\"134\">Tech Stack</span>\n          <p class=\"text-sm text-white font-light\" data-kid=\"135\">React, Next.js, TypeScript, Supabase, TailwindCSS.</p>\n        </div>\n        <div class=\"glass p-8 rounded-2xl border-white/5 group hover:border-[#C47810]/20 transition-premium\" data-kid=\"136\">\n          <span class=\"text-[10px] font-mono text-[#555555] block mb-4 uppercase\" data-kid=\"137\">Markets</span>\n          <p class=\"text-sm text-white font-light\" data-kid=\"138\">Building for Africa and the global digital frontier.</p>\n        </div>\n        <div class=\"col-span-2 glass p-8 rounded-2xl border-white/5 group hover:border-[#C47810]/20 transition-premium\" data-kid=\"139\">\n          <span class=\"text-[10px] font-mono text-[#555555] block mb-4 uppercase\" data-kid=\"140\">Certification</span>\n          <p class=\"text-sm text-white font-light\" data-kid=\"141\">ALX Certified Software Engineer. Detail-obsessed. Deadline-driven.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-40 px-12 md:px-24 bg-[#080808] border-t border-white/5\" data-kid=\"142\">\n    <div class=\"max-w-[1200px] mx-auto\" data-kid=\"143\">\n      <div class=\"mb-24 flex flex-col md:flex-row md:items-end justify-between gap-8\" data-kid=\"144\">\n        <div data-kid=\"145\">\n          <span class=\"text-[10px] font-mono tracking-[0.4em] text-[#C47810] block mb-6 uppercase\" data-kid=\"146\">04 — Methodology</span>\n          <h2 class=\"font-display text-6xl font-light leading-[0.9] text-white\" data-kid=\"147\">\n            A lineage of <br data-kid=\"148\">\n            <span class=\"italic font-light\" data-kid=\"149\">order.</span>\n          </h2>\n        </div>\n        <div class=\"h-[1px] flex-1 mx-12 mb-4 bg-linear-to-r from-white/10 to-transparent hidden md:block\" data-kid=\"150\"></div>\n        <p class=\"max-w-xs text-sm font-light text-[#A0A0A0] leading-relaxed mb-2\" data-kid=\"151\">\n          Precision is not an accident. It is the result of high intention, sincere effort, and intelligent execution.\n        </p>\n      </div>\n\n      \n      <div class=\"relative\" data-kid=\"152\">\n        \n        <div class=\"absolute top-[5px] left-0 right-0 h-[1px] bg-white/10\" data-kid=\"153\"></div>\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-4 gap-12\" data-kid=\"154\">\n          \n          <div class=\"relative pt-8 group\" data-kid=\"155\">\n            <div class=\"absolute top-[-4px] left-0 w-2.5 h-2.5 rounded-full bg-[#C47810] shadow-[0_0_10px_rgba(196,120,16,0.5)] group-hover:scale-150 transition-transform\" data-kid=\"156\"></div>\n            <span class=\"text-[10px] font-mono text-[#555555] block mb-4 uppercase\" data-kid=\"157\">Discovery</span>\n            <h4 class=\"font-display text-2xl font-light text-white mb-4\" data-kid=\"158\">The Blueprint</h4>\n            <p class=\"text-sm text-[#A0A0A0] leading-relaxed\" data-kid=\"159\">Defining the core objective and technical landscape of your vision.</p>\n          </div>\n\n          \n          <div class=\"relative pt-8 group\" data-kid=\"160\">\n            <div class=\"absolute top-[-4px] left-0 w-2.5 h-2.5 rounded-full bg-[#C47810] shadow-[0_0_10px_rgba(196,120,16,0.5)] group-hover:scale-150 transition-transform\" data-kid=\"161\"></div>\n            <span class=\"text-[10px] font-mono text-[#555555] block mb-4 uppercase\" data-kid=\"162\">Design</span>\n            <h4 class=\"font-display text-2xl font-light text-white mb-4\" data-kid=\"163\">Aesthetic Logic</h4>\n            <p class=\"text-sm text-[#A0A0A0] leading-relaxed\" data-kid=\"164\">Crafting high-fidelity interfaces that speak with authority and grace.</p>\n          </div>\n\n          \n          <div class=\"relative pt-8 group\" data-kid=\"165\">\n            <div class=\"absolute top-[-4px] left-0 w-2.5 h-2.5 rounded-full bg-[#C47810] shadow-[0_0_10px_rgba(196,120,16,0.5)] group-hover:scale-150 transition-transform\" data-kid=\"166\"></div>\n            <span class=\"text-[10px] font-mono text-[#555555] block mb-4 uppercase\" data-kid=\"167\">Build</span>\n            <h4 class=\"font-display text-2xl font-light text-white mb-4\" data-kid=\"168\">Pure Syntax</h4>\n            <p class=\"text-sm text-[#A0A0A0] leading-relaxed\" data-kid=\"169\">Translating design into a performant, living digital experience.</p>\n          </div>\n\n          \n          <div class=\"relative pt-8 group\" data-kid=\"170\">\n            <div class=\"absolute top-[-4px] left-0 w-2.5 h-2.5 rounded-full bg-[#C47810] shadow-[0_0_10px_rgba(196,120,16,0.5)] group-hover:scale-150 transition-transform\" data-kid=\"171\"></div>\n            <span class=\"text-[10px] font-mono text-[#555555] block mb-4 uppercase\" data-kid=\"172\">Launch</span>\n            <h4 class=\"font-display text-2xl font-light text-white mb-4\" data-kid=\"173\">The Genesis</h4>\n            <p class=\"text-sm text-[#A0A0A0] leading-relaxed\" data-kid=\"174\">Deployment onto the global edge, optimized for instant delivery.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-40 px-12 md:px-24 bg-[#080808] border-t border-white/5\" data-kid=\"175\">\n    <div class=\"max-w-[1000px] mx-auto text-center\" data-kid=\"176\">\n      <span class=\"text-[10px] font-mono tracking-[0.4em] text-[#C47810] block mb-12 uppercase\" data-kid=\"177\">05 — Voices</span>\n      \n      <div class=\"relative py-12\" data-kid=\"178\">\n        <div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-px h-12 bg-[#C47810]/30\" data-kid=\"179\"></div>\n        <blockquote class=\"font-display text-4xl md:text-5xl font-light italic text-white leading-tight mb-12\" data-kid=\"180\">\n          \"Working with Veltora felt different. Fast, professional, and the final product looked better than I imagined.\"\n        </blockquote>\n        <div class=\"flex flex-col items-center gap-3\" data-kid=\"181\">\n          <span class=\"text-white font-mono text-[10px] tracking-widest uppercase opacity-60\" data-kid=\"182\">EAGLE AIR FLIGHT SCHOOL</span>\n          <div class=\"flex gap-1.5\" data-kid=\"183\">\n            <svg class=\"w-3 h-3 text-[#C47810]\" fill=\"currentColor\" viewBox=\"0 0 20 20\" data-kid=\"184\"><path d=\"M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z\" data-kid=\"185\"></path></svg>\n            <svg class=\"w-3 h-3 text-[#C47810]\" fill=\"currentColor\" viewBox=\"0 0 20 20\" data-kid=\"186\"><path d=\"M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z\" data-kid=\"187\"></path></svg>\n            <svg class=\"w-3 h-3 text-[#C47810]\" fill=\"currentColor\" viewBox=\"0 0 20 20\" data-kid=\"188\"><path d=\"M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1
      "html": "\n<div class=\"w-full bg-[#272735] text-[#FBFCFD] selection:bg-[#5266EB]/30 overflow-x-hidden\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Newsreader:ital,opsz,wght@1,6..72,400;1,6..72,500;1,6..72,600&display=swap');\n\n    :root {\n      --accent: #5266EB;\n      --charcoal: #272735;\n      --cloud: #FBFCFD;\n      --deep-navy: #181623;\n      --tonal-surface: #1E1E2A;\n    }\n\n    body {\n      font-family: 'Plus Jakarta Sans', sans-serif;\n      -webkit-font-smoothing: antialiased;\n    }\n\n    .font-serif {\n      font-family: 'Newsreader', serif;\n    }\n\n    .pill-capsule {\n      border-radius: 9999px;\n    }\n\n    .glass {\n      background: rgba(251, 252, 253, 0.03);\n      backdrop-filter: blur(20px);\n      border: 1px solid rgba(251, 252, 253, 0.1);\n    }\n\n    @keyframes marquee {\n      0% { transform: translateX(0); }\n      100% { transform: translateX(-50%); }\n    }\n    .animate-marquee {\n      animation: marquee 40s linear infinite;\n    }\n\n    .section-spacing {\n      padding-top: 120px;\n      padding-bottom: 120px;\n    }\n\n    .grain::after {\n      content: \"\";\n      position: absolute;\n      inset: 0;\n      background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.05'/%3E%3C/svg%3E\");\n      pointer-events: none;\n      z-index: 50;\n      mix-blend-mode: overlay;\n    }\n  </style>\n\n  \n  <nav class=\"absolute top-0 w-full z-50 flex items-center justify-between px-8 md:px-16 py-10\" data-kid=\"2\">\n    <div class=\"glass pill-capsule flex items-center gap-8 px-8 py-4 w-full max-w-7xl mx-auto\" data-kid=\"3\">\n      <div class=\"text-[#FBFCFD] font-bold text-2xl tracking-tighter\" data-kid=\"4\">VELTORA</div>\n      <div class=\"hidden md:flex items-center gap-10 text-[#FBFCFD]/60 text-sm font-semibold grow justify-center\" data-kid=\"5\">\n        <span class=\"hover:text-[#5266EB] cursor-pointer transition-colors\" data-kid=\"6\">Curation</span>\n        <span class=\"hover:text-[#5266EB] cursor-pointer transition-colors\" data-kid=\"7\">Capabilities</span>\n        <span class=\"hover:text-[#5266EB] cursor-pointer transition-colors\" data-kid=\"8\">Philosophy</span>\n        <span class=\"hover:text-[#5266EB] cursor-pointer transition-colors\" data-kid=\"9\">Inquiry</span>\n      </div>\n      <div class=\"bg-[#5266EB] text-[#FBFCFD] px-8 py-2.5 rounded-full text-xs font-bold tracking-widest uppercase hover:bg-[#4154D1] cursor-pointer transition-all shrink-0\" data-kid=\"10\">\n        Start project\n      </div>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative w-full h-[900px] flex items-center justify-center overflow-hidden bg-[#272735] grain\" data-kid=\"11\">\n    <img src=\"https://images.unsplash.com/photo-1534796636912-3b95b3ab5986?auto=format&w=2000&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover grayscale opacity-30\" alt=\"Veltora Hero\" decoding=\"async\" data-kid=\"12\">\n    <div class=\"absolute inset-0 bg-gradient-to-b from-[#272735]/80 via-transparent to-[#272735]\" data-kid=\"13\"></div>\n    <div class=\"relative z-10 text-center px-6 max-w-5xl\" data-kid=\"14\">\n      <span class=\"text-[#5266EB] font-serif italic text-3xl mb-8 block\" data-kid=\"15\">Mercury Edition</span>\n      <h1 class=\"text-[#FBFCFD] text-7xl md:text-[110px] font-[480] tracking-tighter leading-[0.95] mb-16\" data-kid=\"16\">\n        Precision-built <br data-kid=\"17\"> digital experiences.\n      </h1>\n      <div class=\"flex items-center justify-center gap-4\" data-kid=\"18\">\n        <a href=\"#\" class=\"bg-[#5266EB] text-[#FBFCFD] px-10 py-4 rounded-full text-lg font-medium hover:bg-[#4154D1] transition-all transform hover:scale-105\" data-kid=\"19\">\n          Open account\n        </a>\n      </div>\n    </div>\n    \n    <div class=\"absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3\" data-kid=\"20\">\n        <div class=\"w-px h-12 bg-gradient-to-b from-[#5266EB] to-transparent\" data-kid=\"21\"></div>\n        <span class=\"text-xs font-bold tracking-[0.2em] text-[#FBFCFD]/40 uppercase\" data-kid=\"22\">Explore</span>\n    </div>\n  </section>\n\n  \n  <section class=\"w-full bg-[#272735] section-spacing px-8 md:px-16 overflow-hidden grain\" data-kid=\"23\">\n    <div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-24 items-center\" data-kid=\"24\">\n      <div class=\"space-y-10\" data-kid=\"25\">\n        <div class=\"space-y-4\" data-kid=\"26\">\n            <span class=\"text-[#5266EB] font-bold tracking-widest text-xs uppercase\" data-kid=\"27\">Engineering Philosophy</span>\n            <h2 class=\"text-[#FBFCFD] text-5xl md:text-6xl font-[480] leading-[1.1] tracking-tight\" data-kid=\"28\">\n              Performance led, <br data-kid=\"29\">\n              <span class=\"text-[#5266EB]/80 italic font-serif\" data-kid=\"30\">design perfected.</span>\n            </h2>\n        </div>\n        <div class=\"space-y-6 max-w-lg\" data-kid=\"31\">\n            <p class=\"text-[#FBFCFD]/70 text-lg leading-relaxed font-[360]\" data-kid=\"32\">\n              Veltora is a specialized digital studio dedicated to the craft of building high-performance websites. We reject the generic in favor of technical precision and cinematic aesthetics.\n            </p>\n            <p class=\"text-[#FBFCFD]/50 text-base leading-relaxed font-[360]\" data-kid=\"33\">\n              Every pixel is placed with intent. Every line of code is optimized for speed. This is the Veltora standard—where engineering meets artistry.\n            </p>\n        </div>\n        <div class=\"flex items-center gap-4\" data-kid=\"34\">\n           <div class=\"w-16 h-px bg-[#5266EB]\" data-kid=\"35\"></div>\n           <a href=\"#\" class=\"text-[#FBFCFD] font-serif italic text-xl hover:text-[#5266EB] transition-colors\" data-kid=\"36\">Our methodology</a>\n        </div>\n      </div>\n      \n      <div class=\"relative\" data-kid=\"37\">\n        \n        <div class=\"aspect-[4/3] bg-[#1E1E2A] rounded-[56px] p-10 border border-[#FBFCFD]/5 relative overflow-hidden group\" data-kid=\"38\">\n          <div class=\"absolute inset-0 bg-gradient-to-br from-[#5266EB]/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-1000\" data-kid=\"39\"></div>\n          \n          <div class=\"h-full w-full bg-[#272735] rounded-[40px] border border-[#FBFCFD]/10 flex flex-col shadow-[0_0_100px_rgba(0,0,0,0.5)] overflow-hidden\" data-kid=\"40\">\n            \n            <div class=\"px-6 py-4 border-b border-[#FBFCFD]/5 flex items-center justify-between\" data-kid=\"41\">\n                <div class=\"flex gap-1.5\" data-kid=\"42\">\n                    <div class=\"w-2.5 h-2.5 rounded-full bg-[#FBFCFD]/10\" data-kid=\"43\"></div>\n                    <div class=\"w-2.5 h-2.5 rounded-full bg-[#FBFCFD]/10\" data-kid=\"44\"></div>\n                    <div class=\"w-2.5 h-2.5 rounded-full bg-[#FBFCFD]/10\" data-kid=\"45\"></div>\n                </div>\n                <div class=\"h-2 w-24 bg-[#FBFCFD]/10 rounded-full\" data-kid=\"46\"></div>\n                <div class=\"w-8 h-8 rounded-full bg-[#5266EB]/20 border border-[#5266EB]/40\" data-kid=\"47\"></div>\n            </div>\n            \n            <div class=\"p-8 grow flex gap-8\" data-kid=\"48\">\n                <div class=\"w-1/3 space-y-6\" data-kid=\"49\">\n                    <div class=\"h-40 bg-gradient-to-br from-[#1E1E2A] to-[#272735] rounded-2xl border border-[#FBFCFD]/5 flex items-center justify-center\" data-kid=\"50\">\n                        <span class=\"text-[#5266EB] font-serif italic text-3xl\" data-kid=\"51\">99.9%</span>\n                    </div>\n                    <div class=\"space-y-2\" data-kid=\"52\">\n                        <div class=\"h-2 w-full bg-[#FBFCFD]/10 rounded-full\" data-kid=\"53\"></div>\n                        <div class=\"h-2 w-2/3 bg-[#FBFCFD]/5 rounded-full\" data-kid=\"54\"></div>\n                    </div>\n                    <div class=\"h-32 bg-[#1E1E2A] rounded-2xl border border-[#FBFCFD]/5 p-4\" data-kid=\"55\">\n                        <div class=\"flex flex-col gap-2\" data-kid=\"56\">\n                            <div class=\"h-1 w-1/2 bg-[#5266EB]/40 rounded-full\" data-kid=\"57\"></div>\n                            <div class=\"h-1 w-full bg-[#FBFCFD]/5 rounded-full\" data-kid=\"58\"></div>\n                            <div class=\"h-1 w-3/4 bg-[#FBFCFD]/5 rounded-full\" data-kid=\"59\"></div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"w-2/3 space-y-6\" data-kid=\"60\">\n                    <div class=\"flex gap-4\" data-kid=\"61\">\n                        <div class=\"px-4 py-2 bg-[#5266EB]/10 border border-[#5266EB]/20 rounded-full text-[10px] text-[#5266EB] font-bold uppercase tracking-widest\" data-kid=\"62\">Active State</div>\n                        <div class=\"px-4 py-2 bg-[#FBFCFD]/5 rounded-full text-[10px] text-[#FBFCFD]/30 font-bold uppercase tracking-widest\" data-kid=\"63\">Draft</div>\n                    </div>\n                    <div class=\"h-64 bg-gradient-to-tr from-[#1E1E2A] to-[#272735] rounded-3xl border border-[#FBFCFD]/5 p-8 flex flex-col justify-between\" data-kid=\"64\">\n                        <div class=\"space-y-2\" data-kid=\"65\">\n                            <div class=\"text-[#FBFCFD] text-lg font-bold\" data-kid=\"66\">Metrics.log</div>\n                            <div class=\"text-[#FBFCFD]/20 text-xs font-mono\" data-kid=\"67\">system.request_cycle: 12ms</div>\n                        </div>\n                        <div class=\"h-12 w-1/3 bg-[#5266EB]/80 rounded-full shadow-lg shadow-[#5266EB]/20\" data-kid=\"68\"></div>\n                    </div>\n                </div>\n            </div>\n          </div>\n\n          \n          <div class=\"absolute top-1/4 -right-8 w-48 h-48 glass rounded-[32px] p-6 animate-pulse hidden lg:block\" data-kid=\"69\">\n            <div class=\"h-2 w-1/2 bg-[#FBFCFD]/20 rounded-full mb-4\" data-kid=\"70\"></div>\n            <div class=\"h-20 bg-[#5266EB]/20 rounded-xl mb-4\" data-kid=\"71\"></div>\n            <div class=\"h-2 w-full bg-[#FBFCFD]/10 rounded-full\" data-kid=\"72\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"services\" class=\"w-full bg-[#FBFCFD] section-spacing px-8 md:px-16 text-[#272735]\" data-kid=\"73\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"74\">\n      <div class=\"mb-24 flex flex-col md:flex-row justify-between items-end gap-8\" data-kid=\"75\">\n        <div class=\"space-y-4\" data-kid=\"76\">\n            <span class=\"text-[#5266EB] font-serif italic text-2xl\" data-kid=\"77\">Studio Capabilities</span>\n            <h2 class=\"text-[#272735] text-5xl md:text-7xl font-[480] tracking-tighter\" data-kid=\"78\">Forging the digital <br data-kid=\"79\"> frontier.</h2>\n        </div>\n        <p class=\"text-[#272735]/60 text-lg max-w-sm mb-2 font-[360]\" data-kid=\"80\">\n          We offer three distinct engagement models tailored to the scale of your ambition.\n        </p>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"81\">\n        \n        <div class=\"group p-12 border border-[#272735]/10 rounded-[64px] hover:border-[#5266EB] transition-all duration-700 flex flex-col h-full hover:bg-[#5266EB]/[0.02]\" data-kid=\"82\">\n          <div class=\"w-16 h-16 bg-[#5266EB]/5 rounded-2xl flex items-center justify-center mb-12 group-hover:bg-[#5266EB] transition-all duration-500\" data-kid=\"83\">\n            <svg class=\"w-8 h-8 text-[#5266EB] group-hover:text-white transition-colors\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"84\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M13 10V3L4 14h7v7l9-11h-7z\" data-kid=\"85\"></path></svg>\n          </div>\n          <h3 class=\"text-[#272735] text-3xl font-[480] mb-6\" data-kid=\"86\">Forge</h3>\n          <p class=\"text-[#272735]/60 leading-relaxed mb-12 grow text-lg font-[360]\" data-kid=\"87\">Precise, conversion-led landing pages for product launches and high-impact MVPs. Built for speed.</p>\n          <ul class=\"space-y-4 mb-12 text-sm font-semibold tracking-tight text-[#272735]/80\" data-kid=\"88\">\n            <li class=\"flex items-center gap-3\" data-kid=\"89\"><span class=\"w-2 h-2 rounded-full bg-[#5266EB]\" data-kid=\"90\"></span> Next.js Performance</li>\n            <li class=\"flex items-center gap-3\" data-kid=\"91\"><span class=\"w-2 h-2 rounded-full bg-[#5266EB]\" data-kid=\"92\"></span> Vercel Deployment</li>\n            <li class=\"flex items-center gap-3\" data-kid=\"93\"><span class=\"w-2 h-2 rounded-full bg-[#272735]/10 group-hover:bg-[#5266EB]/20\" data-kid=\"94\"></span> 7-Day Sprint</li>\n          </ul>\n          <a href=\"#\" class=\"inline-flex items-center bg-[#272735] text-white px-8 py-3 rounded-full text-sm font-bold gap-3 group-hover:bg-[#5266EB] transition-all self-start\" data-kid=\"95\">\n            Explore Forge <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"96\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\" data-kid=\"97\"></path></svg>\n          </a>\n        </div>\n\n        \n        <div class=\"group p-12 border border-[#272735]/10 rounded-[64px] hover:border-[#5266EB] transition-all duration-700 flex flex-col h-full hover:bg-[#5266EB]/[0.02]\" data-kid=\"98\">\n          <div class=\"w-16 h-16 bg-[#5266EB]/5 rounded-2xl flex items-center justify-center mb-12 group-hover:bg-[#5266EB] transition-all duration-500\" data-kid=\"99\">\n            <svg class=\"w-8 h-8 text-[#5266EB] group-hover:text-white transition-colors\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"100\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\" data-kid=\"101\"></path></svg>\n          </div>\n          <h3 class=\"text-[#272735] text-3xl font-[480] mb-6\" data-kid=\"102\">Velocity</h3>\n          <p class=\"text-[#272735]/60 leading-relaxed mb-12 grow text-lg font-[360]\" data-kid=\"103\">Comprehensive digital solutions for growing brands. Includes a custom design system and CRM integration.</p>\n          <ul class=\"space-y-4 mb-12 text-sm font-semibold tracking-tight text-[#272735]/80\" data-kid=\"104\">\n            <li class=\"flex items-center gap-3\" data-kid=\"105\"><span class=\"w-2 h-2 rounded-full bg-[#5266EB]\" data-kid=\"106\"></span> Full Design System</li>\n            <li class=\"flex items-center gap-3\" data-kid=\"107\"><span class=\"w-2 h-2 rounded-full bg-[#5266EB]\" data-kid=\"108\"></span> CMS Orchestration</li>\n            <li class=\"flex items-center gap-3\" data-kid=\"109\"><span class=\"w-2 h-2 rounded-full bg-[#272735]/10 group-hover:bg-[#5266EB]/20\" data-kid=\"110\"></span> Bi-weekly Sprints</li>\n          </ul>\n          <a href=\"#\" class=\"inline-flex items-center bg-[#272735] text-white px-8 py-3 rounded-full text-sm font-bold gap-3 group-hover:bg-[#5266EB] transition-all self-start\" data-kid=\"111\">\n            Explore Velocity <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"112\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\" data-kid=\"113\"></path></svg>\n          </a>\n        </div>\n\n        \n        <div class=\"group p-12 border border-[#272735]/10 rounded-[64px] hover:border-[#5266EB] transition-all duration-700 flex flex-col h-full hover:bg-[#5266EB]/[0.02]\" data-kid=\"114\">\n          <div class=\"w-16 h-16 bg-[#5266EB]/5 rounded-2xl flex items-center justify-center mb-12 group-hover:bg-[#5266EB] transition-all duration-500\" data-kid=\"115\">\n            <svg class=\"w-8 h-8 text-[#5266EB] group-hover:text-white transition-colors\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"116\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-7.714 2.143L11 21l-2.286-6.857L1 12l7.714-2.143L11 3z\" data-kid=\"117\"></path></svg>\n          </div>\n          <h3 class=\"text-[#272735] text-3xl font-[480] mb-6\" data-kid=\"118\">Apex</h3>\n          <p class=\"text-[#272735]/60 leading-relaxed mb-12 grow text-lg font-[360]\" data-kid=\"119\">Enterprise-grade digital ecosystems. Custom web apps built on Supabase with dedicated ongoing support.</p>\n          <ul class=\"space-y-4 mb-12 text-sm font-semibold tracking-tight text-[#272735]/80\" data-kid=\"120\">\n            <li class=\"flex items-center gap-3\" data-kid=\"121\"><span class=\"w-2 h-2 rounded-full bg-[#5266EB]\" data-kid=\"122\"></span> Full-stack Auth</li>\n            <li class=\"flex items-center gap-3\" data-kid=\"123\"><span class=\"w-2 h-2 rounded-full bg-[#5266EB]\" data-kid=\"124\"></span> Real-time Backend</li>\n            <li class=\"flex items-center gap-3\" data-kid=\"125\"><span class=\"w-2 h-2 rounded-full bg-[#272735]/10 group-hover:bg-[#5266EB]/20\" data-kid=\"126\"></span> Retainer Managed</li>\n          </ul>\n          <a href=\"#\" class=\"inline-flex items-center bg-[#272735] text-white px-8 py-3 rounded-full text-sm font-bold gap-3 group-hover:bg-[#5266EB] transition-all self-start\" data-kid=\"127\">\n            Explore Apex <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"128\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\" data-kid=\"129\"></path></svg>\n          </a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"work\" class=\"w-full bg-[#272735] section-spacing px-8 md:px-16 overflow-hidden\" data-kid=\"130\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"131\">\n        <div class=\"flex flex-col md:flex-row justify-between items-start md:items-end mb-24 gap-12\" data-kid=\"132\">\n            <div class=\"space-y-4\" data-kid=\"133\">\n                <span class=\"text-[#5266EB] font-serif italic text-2xl\" data-kid=\"134\">Selected Works</span>\n                <h2 class=\"text-[#FBFCFD] text-5xl md:text-7xl font-[480] tracking-tight\" data-kid=\"135\">Digital artifacts.</h2>\n            </div>\n            <div class=\"border border-[#FBFCFD]/20 text-[#FBFCFD] px-10 py-4 rounded-full text-xs font-bold tracking-widest uppercase hover:bg-[#FBFCFD] hover:text-[#272735] cursor-pointer transition-all\" data-kid=\"136\">\n                View Archive\n            </div>\n        </div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-20\" data-kid=\"137\">\n            \n            <div class=\"group cursor-pointer\" data-kid=\"138\">\n                <div class=\"aspect-[16/10] bg-[#1E1E2A] rounded-[64px] overflow-hidden border border-[#FBFCFD]/5 mb-12 relative\" data-kid=\"139\">\n                    <img src=\"https://images.unsplash.com/photo-1464012356351-a9f938234320?auto=format&w=1200&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 opacity-60 group-hover:opacity-100 group-hover:scale-110\" alt=\"Eagle Air\" decoding=\"async\" data-kid=\"140\">\n                    <div class=\"absolute inset-0 bg-gradient-to-t from-[#272735]/60 via-transparent to-transparent\" data-kid=\"141\"></div>\n                    <div class=\"absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-500\" data-kid=\"142\">\n                        <div class=\"bg-[#5266EB] text-white px-12 py-5 rounded-full font-bold tracking-widest uppercase text-xs\" data-kid=\"143\">View Case Study</div>\n                    </div>\n                </div>\n                <div class=\"flex justify-between items-start px-4\" data-kid=\"144\">\n                    <div class=\"space-y-2\" data-kid=\"145\">\n                        <h4 class=\"text-[#FBFCFD] text-2xl font-[480]\" data-kid=\"146\">Eagle Air Flight School</h4>\n                        <p class=\"text-[#FBFCFD]/40 text-sm font-medium tracking-wide\" data-kid=\"147\">Education / Aviation Platform</p>\n                    </div>\n                    <span class=\"text-[#5266EB] font-serif italic text-xl\" data-kid=\"148\">2024</span>\n                </div>\n            </div>\n\n            \n            <div class=\"group cursor-pointer\" data-kid=\"149\">\n                <div class=\"aspect-[16/10] bg-[#1E1E2A] rounded-[64px] overflow-hidden border border-[#FBFCFD]/5 mb-12 relative\" data-kid=\"150\">\n                    <img src=\"https://images.unsplash.com/photo-1497215728101-856f4ea42174?auto=format&w=1200&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 opacity-60 group-hover:opacity-100 group-hover:scale-110\" alt=\"ELI Two\" decoding=\"async\" data-kid=\"151\">\n                    <div class=\"absolute inset-0 bg-gradient-to-t from-[#272735]/60 via-transparent to-transparent\" data-kid=\"152\"></div>\n                    <div class=\"absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-500\" data-kid=\"153\">\n                        <div class=\"bg-[#5266EB] text-white px-12 py-5 rounded-full font-bold tracking-widest uppercase text-xs\" data-kid=\"154\">View Case Study</div>\n                    </div>\n                </div>\n                <div class=\"flex justify-between items-start px-4\" data-kid=\"155\">\n                    <div class=\"space-y-2\" data-kid=\"156\">\n                        <h4 class=\"text-[#FBFCFD] text-2xl font-[480]\" data-kid=\"157\">ELI Two Corporate</h4>\n                        <p class=\"text-[#FBFCFD]/40 text-sm font-medium tracking-wide\" data-kid=\"158\">Business / Financial Services</p>\n                    </div>\n                    <span class=\"text-[#5266EB] font-serif italic text-xl\" data-kid=\"159\">2024</span>\n                </div>\n            </div>\n        </div>\n    </div>\n  </section>\n\n  \n  <section class=\"w-full bg-[#FBFCFD] section-spacing px-8 md:px-16 text-[#272735]\" data-kid=\"160\">\n    <div class=\"max-w-5xl mx-auto text-center\" data-kid=\"161\">\n      <div class=\"mb-16\" data-kid=\"162\">\n          <svg class=\"w-20 h-20 text-[#5266EB]/10 mx-auto\" fill=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"163\"><path d=\"M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H16.017C14.9124 8 14.017 7.10457 14.017 6V3L11.017 3V21H14.017ZM5.017 21L5.017 18C5.017 16.8954 5.91243 16 7.017 16H10.017C10.5693 16 11.017 15.5523 11.017 15V9C11.017 8.44772 10.5693 8 10.017 8H7.017C5.91243 8 5.017 7.10457 5.017 6V3L2.017 3V21H5.017Z\" data-kid=\"164\"></path></svg>\n      </div>\n      <blockquote class=\"text-[#272735] text-4xl md:text-6xl font-serif italic leading-[1.15] tracking-tight mb-12\" data-kid=\"165\">\n          \"Veltora transformed our digital presence from a generic template to a high-performance engine. Their precision and cinematic eye are unmatched.\"\n      </blockquote>\n      <div class=\"flex flex-col items-center gap-6\" data-kid=\"166\">\n          <img src=\"https://i.pravatar.cc/150?u=sarah\" class=\"w-24 h-24 rounded-full grayscale border-2 border-[#5266EB]/20\" alt=\"Sarah J.\" decoding=\"async\" data-kid=\"167\">\n          <div class=\"space-y-2\" data-kid=\"168\">\n              <p class=\"text-[#272735] font-bold text-2xl tracking-tight\" data-kid=\"169\">Sarah Jenkins</p>\n              <p class=\"text-[#272735]/40 text-xs font-bold tracking-[0.3em] uppercase\" data-kid=\"170\">CEO, AeroTech Global</p>\n          </div>\n      </div>\n    </div>\n\n    \n    <div class=\"mt-24 overflow-hidden relative select-none\" data-kid=\"171\">\n      <div class=\"flex items-center gap-24 whitespace-nowrap animate-marquee opacity-20 grayscale\" data-kid=\"172\">\n          <span class=\"text-[#272735] text-3xl font-bold tracking-tighter\" data-kid=\"173\">AEROTECH</span>\n          <span class=\"text-[#272735] text-3xl font-bold tracking-tighter\" data-kid=\"174\">LUMINA</span>\n          <span class=\"text-[#272735] text-3xl font-bold tracking-tighter\" data-kid=\"175\">QUANTUM</span>\n          <span class=\"text-[#272735] text-3xl font-bold tracking-tighter\" data-kid=\"176\">ZENITH</span>\n          <span class=\"text-[#272735] text-3xl font-bold tracking-tighter\" data-kid=\"177\">VERIDIAN</span>\n          <span class=\"text-[#272735] text-3xl font-bold tracking-tighter\" data-kid=\"178\">NEXUS</span>\n          <span class=\"text-[#272735] text-3xl font-bold tracking-tighter\" data-kid=\"179\">AEROTECH</span>\n          <span class=\"text-[#272735] text-3xl font-bold tracking-tighter\" data-kid=\"180\">LUMINA</span>\n          <span class=\"text-[#272735] text-3xl font-bold tracking-tighter\" data-kid=\"181\">QUANTUM</span>\n          <span class=\"text-[#272735] text-3xl font-bold tracking-tighter\" data-kid=\"182\">ZENITH</span>\n          <span class=\"text-[#272735] text-3xl font-bold tracking-tighter\" data-kid=\"183\">VERIDIAN</span>\n          <span class=\"text-[#272735] text-3xl font-bold tracking-tighter\" data-kid=\"184\">NEXUS</span>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"contact\" class=\"w-full